// DAL CEO — CLI entry point
// Run: dal run main.dal
// Sends a single prompt to the agent (with evolve context) and prints the reply.
// For the full HTTP server, use: dal serve server.dal --port 4040

fn main() {
    let ctx = "";
    try {
        ctx = evolve::load();
    } catch {
        // no context yet
    }

    print("DAL CEO v0.2.0");
    print("Context loaded: " + to_string(len(ctx)) + " chars");
    print("---");

    let prompt = "What can you do? List your capabilities briefly.";
    let enriched = prompt;
    if (ctx != null && len(ctx) > 0) {
        enriched = "## Context\n\n" + ctx + "\n\n---\n\n" + prompt;
    }

    let reply = "";
    try {
        reply = ai::respond_with_tools(enriched);
    } catch {
        reply = "AI not configured. Set OPENAI_API_KEY in .env and run: export $(grep -v '^#' .env | xargs) && dal run main.dal";
    }

    print(reply);
}

main();
