// UI built in DAL: HTML, CSS, JS for the agent assistant web UI.
// Prefer static/ files when base path is set; otherwise return minimal inline content.
// Use: import "./web.dal" as web;  body = web::get_index_html(base);

fn read_from_static(base, filename) {
 try {
  let path = "static/" + filename;
  if (len(base) > 0) { path = base + "/static/" + filename; }
  let out = sh::run("cat " + path + " 2>/dev/null");
  if (out != null && len(out) > 0) {
   return out;
  }
 } catch {
  // ignore
 }
 return null;
}

fn get_index_html(base) {
 let body = read_from_static(base, "index.html");
 if (body != null && len(body) > 0) {
  return body;
 }
 return default_index_html();
}

fn get_styles_css(base) {
 let body = read_from_static(base, "styles.css");
 if (body != null && len(body) > 0) {
  return body;
 }
 return default_styles_css();
}

fn get_app_js(base) {
 let body = read_from_static(base, "app.js");
 if (body != null && len(body) > 0) {
  return body;
 }
 return default_app_js();
}

// Minimal fallbacks when static/ is not available (built in DAL)
fn default_index_html() {
 return "<!DOCTYPE html><html lang=\"en\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Agent Assistant</title><link rel=\"stylesheet\" href=\"/styles.css\"></head><body><div class=\"header\"><h1>Agent Assistant</h1><p>Chat, run commands, or give tasks. Memory-enabled.</p><div class=\"ai-status\" id=\"ai-status\"><span class=\"ai-dot checking\" id=\"ai-dot\"></span><span id=\"ai-label\">Checking…</span></div><div class=\"ai-fix\" id=\"ai-fix\" style=\"display:none\"></div></div><div class=\"layout\"><main class=\"chat-main\"><div id=\"messages\"></div><form class=\"input-bar\" id=\"form\"><input type=\"text\" id=\"input\" placeholder=\"Message your agent...\" autocomplete=\"off\"><button type=\"submit\">Send</button></form></main><aside class=\"panels\"><div class=\"tabs\"><button type=\"button\" class=\"tab active\" data-panel=\"history\">History</button><button type=\"button\" class=\"tab\" data-panel=\"task\">Task</button><button type=\"button\" class=\"tab\" data-panel=\"workflow\">Workflow</button></div><section class=\"panel active\" id=\"panel-history\"><div class=\"panel-header\"><h2>History</h2><button type=\"button\" id=\"history-refresh\">↻</button><button type=\"button\" id=\"history-clear\">Clear</button></div><div id=\"history-list\" class=\"history-list\"></div></section><section class=\"panel\" id=\"panel-task\"><div class=\"panel-header\"><h2>Task</h2></div><form id=\"task-form\" class=\"panel-form\"><textarea id=\"task-input\" placeholder=\"Describe the task...\" rows=\"3\"></textarea><button type=\"submit\">Run task</button></form><div id=\"task-result\" class=\"panel-result\"></div></section><section class=\"panel\" id=\"panel-workflow\"><div class=\"panel-header\"><h2>Workflow</h2></div><form id=\"workflow-form\" class=\"panel-form\"><label for=\"workflow-select\">Workflow</label><select id=\"workflow-select\"><option value=\"\">Loading…</option></select><label for=\"workflow-input\">Input</label><input type=\"text\" id=\"workflow-input\" placeholder=\"e.g. topic\"><button type=\"submit\">Run workflow</button></form><div id=\"workflow-result\" class=\"panel-result\"></div></section></aside></div><script src=\"/app.js\"></script></body></html>";
}

fn default_styles_css() {
 return "*{box-sizing:border-box;margin:0;padding:0}body{font-family:system-ui,sans-serif;background:#0a0a0f;color:#e4e4e7;min-height:100vh;display:flex;flex-direction:column}.header{padding:1rem 1.25rem;border-bottom:1px solid #1e1e2e;background:#0f0f18}.header h1{font-size:1.1rem;font-weight:600}.header p{color:#52525b;font-size:0.8rem;margin-top:0.25rem}.ai-status{display:inline-flex;align-items:center;gap:0.35rem;font-size:0.7rem;color:#52525b;margin-top:0.4rem}.ai-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}.ai-dot.connected{background:#00d4aa}.ai-dot.disconnected{background:#ef4444}.ai-dot.checking{background:#eab308;animation:pulse 1s ease-in-out infinite}@keyframes pulse{50%{opacity:.4}}.ai-fix{margin-top:0.5rem;padding:0.5rem 0.75rem;background:#141420;border:1px solid #1e1e2e;border-radius:6px;font-size:0.7rem;color:#71717a}.layout{display:flex;flex:1;min-height:0}.chat-main{flex:1;display:flex;flex-direction:column;min-width:0}#messages{flex:1;overflow-y:auto;padding:1rem;display:flex;flex-direction:column;gap:0.6rem}.msg{padding:0.6rem 0.85rem;border-radius:10px;max-width:85%;line-height:1.5;font-size:0.9rem}.msg.user{background:#1a1a2e;align-self:flex-start;border:1px solid #252540}.msg.agent{background:#0f1a1a;align-self:flex-end;border:1px solid #0d3d3d}.msg .who{font-size:0.65rem;color:#52525b;margin-bottom:0.2rem}.input-bar{display:flex;gap:0.5rem;padding:1rem;border-top:1px solid #1e1e2e;background:#0f0f18}.input-bar input{flex:1;padding:0.65rem 0.85rem;border-radius:8px;border:1px solid #252540;background:#141420;color:#e4e4e7;font-size:0.9rem}.input-bar button{padding:0.65rem 1.1rem;border-radius:8px;border:none;background:#00d4aa;color:#0a0a0f;font-weight:600;cursor:pointer}.panels{width:320px;border-left:1px solid #1e1e2e;background:#0f0f18;display:flex;flex-direction:column}.tabs{display:flex;border-bottom:1px solid #1e1e2e}.tab{flex:1;padding:0.6rem;font-size:0.8rem;background:#141420;border:none;color:#71717a;cursor:pointer}.tab.active{color:#00d4aa;background:#0f0f18;font-weight:600}.panel{display:none;flex:1;flex-direction:column;overflow:auto;padding:0.75rem}.panel.active{display:flex}.panel-header{display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem}.panel-header h2{font-size:0.85rem}.panel-form textarea,.panel-form input{width:100%;padding:0.5rem;border-radius:6px;border:1px solid #252540;background:#141420;color:#e4e4e7;font-size:0.85rem}.panel-form button{margin-top:0.5rem;padding:0.5rem 0.85rem;border-radius:6px;border:none;background:#00d4aa;color:#0a0a0f;font-weight:600;cursor:pointer}.panel-result{margin-top:0.75rem;padding:0.65rem;background:#141420;border:1px solid #1e1e2e;border-radius:8px;font-size:0.8rem;max-height:200px;overflow-y:auto}.history-list{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:0.5rem}.history-item{padding:0.5rem 0.65rem;background:#141420;border:1px solid #1e1e2e;border-radius:8px;font-size:0.75rem}.history-item .meta{color:#71717a}.history-item .content{color:#d4d4d8}.history-item .reply{color:#a1a1aa;margin-top:0.35rem;padding-top:0.35rem;border-top:1px solid #1e1e2e}";
}

fn default_app_js() {
 return "(function(){var apiBase=window.location.origin,m=document.getElementById('messages'),f=document.getElementById('form'),i=document.getElementById('input'),aiDot=document.getElementById('ai-dot'),aiLabel=document.getElementById('ai-label'),aiFix=document.getElementById('ai-fix');function setStatus(ok,msg){aiDot.className='ai-dot '+(ok?'connected':'disconnected');aiLabel.textContent=ok?'LLM connected':(msg||'LLM disconnected');aiFix.style.display=ok?'none':'block';if(!ok)aiFix.innerHTML='<strong>Setup:</strong> Set OPENAI_API_KEY in .env and restart.'}(async function(){try{var r=await fetch(apiBase+'/api/ai-status'),d=await r.json().catch(function(){});setStatus(!!d.connected,d.message);}catch(e){setStatus(false,'Cannot reach server');}})();setInterval(function(){fetch(apiBase+'/api/ai-status').then(function(r){return r.json();}).then(function(d){setStatus(!!d.connected,d.message);}).catch(function(){setStatus(false);});},45000);function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');}function nl2br(s){return String(s).replace(/\\n/g,'<br>');}function addMsg(who,text){var d=document.createElement('div');d.className='msg '+who;d.innerHTML='<div class=\"who\">'+who+'</div><div>'+nl2br(esc(text))+'</div>';m.appendChild(d);m.scrollTop=m.scrollHeight;}f.addEventListener('submit',async function(e){e.preventDefault();var c=i.value.trim();if(!c)return;addMsg('user',c);i.value='';i.focus();try{var r=await fetch(apiBase+'/api/message',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({sender_id:'web',content:c})});var d=await r.json().catch(function(){});addMsg('agent',d.reply||d.error||(r.ok?'No reply':'Error '+r.status));}catch(err){addMsg('agent','Error: '+(err&&err.message||String(err)));}});var hList=document.getElementById('history-list'),hRef=document.getElementById('history-refresh'),hClr=document.getElementById('history-clear');function renderHist(entries){hList.innerHTML='';if(!entries||entries.length===0){hList.innerHTML='<div class=\"history-empty\">No history yet.</div>';return;}entries.forEach(function(e){var el=document.createElement('div');el.className='history-item';el.innerHTML='<div class=\"meta\">'+(e.ts||'')+' · '+(e.type||'')+' · '+esc(e.sender||'')+'</div><div class=\"content\">'+nl2br(esc((e.content||'').slice(0,200)))+'</div>'+(e.reply?'<div class=\"reply\">'+nl2br(esc((e.reply||'').slice(0,150)))+'</div>':'');hList.appendChild(el);});}async function refreshHist(){try{var r=await fetch(apiBase+'/api/history'),d=await r.json().catch(function(){});if(d.ok&&Array.isArray(d.entries))renderHist(d.entries);else renderHist([]);}catch(e){renderHist([]);}}if(hRef)hRef.addEventListener('click',refreshHist);if(hClr)hClr.addEventListener('click',async function(){if(!confirm('Clear history?'))return;await fetch(apiBase+'/api/history/clear',{method:'POST'});refreshHist();});refreshHist();var taskForm=document.getElementById('task-form'),taskIn=document.getElementById('task-input'),taskRes=document.getElementById('task-result');if(taskForm)taskForm.addEventListener('submit',async function(e){e.preventDefault();var desc=(taskIn&&taskIn.value.trim())||'';if(!desc)return;taskRes.textContent='Running…';taskRes.className='panel-result loading';try{var r=await fetch(apiBase+'/api/task',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({description:desc})});var d=await r.json().catch(function(){});taskRes.className='panel-result';taskRes.textContent=d.error?d.error:(d.result||'Done.');if(!d.error)refreshHist();}catch(err){taskRes.className='panel-result error';taskRes.textContent='Error: '+err.message;});});var wfForm=document.getElementById('workflow-form'),wfSel=document.getElementById('workflow-select'),wfIn=document.getElementById('workflow-input'),wfRes=document.getElementById('workflow-result');async function loadWf(){try{var r=await fetch(apiBase+'/api/workflow/list'),d=await r.json().catch(function(){});wfSel.innerHTML='';if(d.ok&&Array.isArray(d.workflows))d.workflows.forEach(function(w){var o=document.createElement('option');o.value=w.name;o.textContent=w.name+(w.description?' — '+w.description.slice(0,40):'');wfSel.appendChild(o);});else{wfSel.innerHTML='<option value=\"\">No workflows</option>';}}catch(e){wfSel.innerHTML='<option value=\"\">Failed to load</option>';}}if(wfForm)wfForm.addEventListener('submit',async function(e){e.preventDefault();var name=wfSel.value,inp=wfIn&&wfIn.value.trim();if(!name||!inp)return;wfRes.textContent='Running…';wfRes.className='panel-result loading';try{var r=await fetch(apiBase+'/api/workflow',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({workflow:name,input:inp})});var d=await r.json().catch(function(){});wfRes.className='panel-result';wfRes.textContent=d.error?d.error:(d.final_result||'Done.');if(!d.error)refreshHist();}catch(err){wfRes.className='panel-result error';wfRes.textContent='Error: '+err.message;});});loadWf();document.querySelectorAll('.tab').forEach(function(tab){tab.addEventListener('click',function(){var id=tab.getAttribute('data-panel');document.querySelectorAll('.tab').forEach(function(t){t.classList.remove('active');});document.querySelectorAll('.panel').forEach(function(p){p.classList.remove('active');});tab.classList.add('active');var p=document.getElementById('panel-'+id);if(p)p.classList.add('active');});});})();";
}
