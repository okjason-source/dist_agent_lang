   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"Missing body\"}"
   };
  }
  let body = json::parse(body_str);
  let role = body["role"];
  let task = body["task"];
  if (role == null || task == null) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"role and task are required\"}"
   };
  }

  log::info("agents", "API run: " + role + " task: " + task);
