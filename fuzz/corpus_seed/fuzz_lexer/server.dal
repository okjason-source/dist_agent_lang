// Agent Assistant — HTTP server with memory (evolve) and tool-using AI.
// Run: dal serve server.dal --port 4040
//
// Routes:
//   GET  /              — Chat UI
//   POST /api/message   — Send message, get AI reply (with context)
//   POST /api/task      — Task execution
//   POST /api/send      — Send outbound message to a channel
//   GET  /api/context   — View current agent memory
//   GET  /api/ai-status — LLM connection check
//   GET  /health        — Liveness

import "./communications.dal" as comms;
import "./agents.dal" as agents;
import "./workflows.dal" as workflows;

// ---------------------------------------------------------------------------
// Startup — validate config
// ---------------------------------------------------------------------------

fn check_config() {
 let ai_cfg = config::get_ai_config();
 let model = ai_cfg["model"];
 log::info("agent-assistant", "Starting v0.2.0");
 log::info("config", "AI model: " + to_string(model));

 try {
  let key = config::get_env("OPENAI_API_KEY");
  log::info("config", "OPENAI_API_KEY is set");
 } catch {
  try {
   let key = config::get_env("DAL_OPENAI_API_KEY");
   log::info("config", "DAL_OPENAI_API_KEY is set");
  } catch {
   try {
    let key = config::get_env("ANTHROPIC_API_KEY");
    log::info("config", "ANTHROPIC_API_KEY is set");
   } catch {
    log::info("config", "WARNING: No AI API key found — set OPENAI_API_KEY or DAL_OPENAI_API_KEY in .env");
   }
  }
 }
}

check_config();

// ---------------------------------------------------------------------------
// Server metrics (in-memory counters, reset on restart)
// ---------------------------------------------------------------------------

let metrics_messages = 0;
let metrics_tasks = 0;
let metrics_sends = 0;
let metrics_errors = 0;

fn get_metrics() {
 return {
  "messages_handled": metrics_messages,
  "tasks_completed": metrics_tasks,
  "outbound_sends": metrics_sends,
  "errors": metrics_errors
 };
}

fn load_agent_runtime() {
 try {
  let raw = sh::run("cat .dal/agent_runtime.json 2>/dev/null");
  if (raw != null && len(raw) > 0) {
   return json::parse(raw);
  }
 } catch {
  // file may not exist yet
 }
 return null;
}

// ---------------------------------------------------------------------------
// Context / memory helpers
// ---------------------------------------------------------------------------

let CONTEXT_MAX_LINES = 200;

fn load_context() {
 try {
  let ctx = evolve::load();
  if (ctx == null) {
   return "";
  }
  return ctx;
 } catch {
  return "";
 }
}

fn load_skills_context() {
 try {
  let raw = sh::run("cat skills/*.skill.dal 2>/dev/null");
  if (raw == null || len(raw) == 0) {
   return "";
  }
  // Extract skill names and descriptions from the raw .skill.dal content
  let descriptions = sh::run("grep -E '^\\s*(skill|description)' skills/*.skill.dal 2>/dev/null | sed 's/^.*skill /Skill: /; s/^.*description /  /; s/[\"{}]//g'");
  if (descriptions == null || len(descriptions) == 0) {
   return "";
  }
  return descriptions;
 } catch {
  return "";
 }
}

fn enrich_prompt(user_message) {
 let ctx = load_context();
 let skills = load_skills_context();
 let prompt = user_message;

 let has_ctx = (ctx != null && len(ctx) > 0);
 let has_skills = (skills != null && len(skills) > 0);

 if (!has_ctx && !has_skills) {
  return prompt;
 }

 let prefix = "";
 if (has_skills) {
  prefix = "## Your skills and capabilities\n\n" + skills + "\n\nYou can send outbound messages using the /api/send endpoint or by running curl commands to channel APIs (Telegram, Discord, iMessage). When a user's sender_id starts with telegram_, discord_, or imessage_, you can reply through that channel.\n\n---\n\n";
 }
 if (has_ctx) {
  prefix = prefix + "## Recent memory (context from previous interactions)\n\n" + ctx + "\n\n---\n\n";
 }

 return prefix + "## Current message\n\n" + prompt;
}

fn log_conversation(user_msg, agent_reply) {
 try {
  evolve::append_conversation(user_msg, agent_reply);
 } catch {
  // evolve write failed — non-fatal
 }
}

fn log_action(action, detail, result) {
 try {
  evolve::append_log(action, detail, result);
 } catch {
  // non-fatal
 }
}

fn trim_context() {
 try {
  evolve::trim_retention(CONTEXT_MAX_LINES);
 } catch {
  // non-fatal
 }
}

// ---------------------------------------------------------------------------
// Conversation history (JSONL file — one JSON object per line)
// ---------------------------------------------------------------------------

let HISTORY_FILE = "history.jsonl";
let HISTORY_MAX_ENTRIES = 500;

fn history_append(sender_id, content, reply, entry_type) {
 try {
  let ts = sh::run("date -u '+%Y-%m-%dT%H:%M:%SZ'");
  if (ts != null) {
   // Trim trailing newline from date output
   ts = sh::run("echo -n '" + ts + "'");
  }
  let entry = {
   "ts": ts,
   "type": entry_type,
   "sender": sender_id,
   "content": content,
   "reply": reply
  };
  let line = json::stringify(entry);
  // Escape single quotes in the JSON line for the shell
  let safe_line = sh::run("printf '%s' '" + line + "'");
  sh::run("echo '" + safe_line + "' >> " + HISTORY_FILE);
 } catch {
  // non-fatal — history write failed
 }
}

fn history_read(max_entries) {
 try {
  let raw = sh::run("tail -n " + to_string(max_entries) + " " + HISTORY_FILE + " 2>/dev/null");
  if (raw == null || len(raw) == 0) {
   return "[]";
  }
  // Wrap JSONL lines into a JSON array
  let arr = sh::run("tail -n " + to_string(max_entries) + " " + HISTORY_FILE + " 2>/dev/null | python3 -c \"import sys; lines=[l.strip() for l in sys.stdin if l.strip()]; print('[' + ','.join(lines) + ']')\"");
  if (arr == null || len(arr) == 0) {
   return "[]";
  }
  return arr;
 } catch {
  return "[]";
 }
}

fn history_count() {
 try {
  let count_str = sh::run("wc -l < " + HISTORY_FILE + " 2>/dev/null");
  if (count_str != null && len(count_str) > 0) {
   return to_int(count_str);
  }
 } catch {
  // file doesn't exist yet
 }
 return 0;
}

fn history_trim() {
 try {
  let count = history_count();
  if (count > HISTORY_MAX_ENTRIES) {
   let keep = to_string(HISTORY_MAX_ENTRIES);
   sh::run("tail -n " + keep + " " + HISTORY_FILE + " > " + HISTORY_FILE + ".tmp && mv " + HISTORY_FILE + ".tmp " + HISTORY_FILE);
   log::info("history", "trimmed to " + keep + " entries");
  }
 } catch {
  // non-fatal
 }
}

// ---------------------------------------------------------------------------
// Web UI: self-contained in this file for robustness. Tries static/ via sh, then inline fallback.
// No import needed — keeps the agent assistant runnable with plain dal serve.
// ---------------------------------------------------------------------------

fn get_ui_base() {
 let base = "";
 try {
  let root = config::get_env("DAL_SERVER_ROOT");
  if (root != null && len(root) > 0) { base = root; }
 } catch { }
 if (len(base) == 0) {
  try {
   let root = config::get_env("VIBES_JOB_ROOT");
   if (root != null && len(root) > 0) { base = root; }
  } catch { }
 }
 return base;
}

fn read_from_static(base, filename) {
 try {
  let path = "static/" + filename;
  if (len(base) > 0) { path = base + "/static/" + filename; }
  let out = sh::run("cat " + path + " 2>/dev/null");
  if (out != null && len(out) > 0) {
   return out;
  }
 } catch {
  // ignore
 }
 return null;
}

fn get_index_html(base) {
 let body = read_from_static(base, "index.html");
 if (body != null && len(body) > 0) {
  return body;
 }
 return default_index_html();
}

fn get_styles_css(base) {
 let body = read_from_static(base, "styles.css");
 if (body != null && len(body) > 0) {
  return body;
 }
 return default_styles_css();
}

fn get_app_js(base) {
 let body = read_from_static(base, "app.js");
 if (body != null && len(body) > 0) {
  return body;
 }
 return default_app_js();
}

fn default_index_html() {
 return "<!DOCTYPE html><html lang=\"en\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Agent Assistant</title><link rel=\"stylesheet\" href=\"/styles.css\"></head><body><div class=\"header\"><h1>Agent Assistant</h1><p>Chat, run commands, or give tasks. Memory-enabled.</p><div class=\"ai-status\" id=\"ai-status\"><span class=\"ai-dot checking\" id=\"ai-dot\"></span><span id=\"ai-label\">Checking…</span></div><div class=\"ai-fix\" id=\"ai-fix\"></div></div><div class=\"layout\"><main class=\"chat-main\"><div id=\"messages\"></div><form class=\"input-bar\" id=\"form\"><input type=\"text\" id=\"input\" placeholder=\"Message your agent...\" autocomplete=\"off\"><button type=\"submit\">Send</button></form></main><aside class=\"panels\"><div class=\"tabs\"><button type=\"button\" class=\"tab active\" data-panel=\"history\">History</button><button type=\"button\" class=\"tab\" data-panel=\"task\">Task</button><button type=\"button\" class=\"tab\" data-panel=\"workflow\">Workflow</button></div><section class=\"panel active\" id=\"panel-history\"><div class=\"panel-header\"><h2>History</h2><button type=\"button\" id=\"history-refresh\">↻</button><button type=\"button\" id=\"history-clear\">Clear</button></div><div id=\"history-list\" class=\"history-list\"></div></section><section class=\"panel\" id=\"panel-task\"><div class=\"panel-header\"><h2>Task</h2></div><form id=\"task-form\" class=\"panel-form\"><textarea id=\"task-input\" placeholder=\"Describe the task...\" rows=\"3\"></textarea><button type=\"submit\">Run task</button></form><div id=\"task-result\" class=\"panel-result\"></div></section><section class=\"panel\" id=\"panel-workflow\"><div class=\"panel-header\"><h2>Workflow</h2></div><form id=\"workflow-form\" class=\"panel-form\"><label for=\"workflow-select\">Workflow</label><select id=\"workflow-select\"><option value=\"\">Loading…</option></select><label for=\"workflow-input\">Input</label><input type=\"text\" id=\"workflow-input\" placeholder=\"e.g. topic\"><button type=\"submit\">Run workflow</button></form><div id=\"workflow-result\" class=\"panel-result\"></div></section></aside></div><script src=\"/app.js\"></script></body></html>";
}

fn default_styles_css() {
 return "*{box-sizing:border-box;margin:0;padding:0}body{font-family:system-ui,sans-serif;background:#0a0a0f;color:#e4e4e7;min-height:100vh;display:flex;flex-direction:column}.header{padding:1rem 1.25rem;border-bottom:1px solid #1e1e2e;background:#0f0f18}.header h1{font-size:1.1rem;font-weight:600}.header p{color:#52525b;font-size:0.8rem;margin-top:0.25rem}.ai-status{display:inline-flex;align-items:center;gap:0.35rem;font-size:0.7rem;color:#52525b;margin-top:0.4rem}.ai-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}.ai-dot.connected{background:#00d4aa}.ai-dot.disconnected{background:#ef4444}.ai-dot.checking{background:#eab308;animation:pulse 1s ease-in-out infinite}@keyframes pulse{50%{opacity:.4}}.ai-fix{margin-top:0.5rem;padding:0.5rem 0.75rem;background:#141420;border:1px solid #1e1e2e;border-radius:6px;font-size:0.7rem;color:#71717a}.layout{display:flex;flex:1;min-height:0}.chat-main{flex:1;display:flex;flex-direction:column;min-width:0}#messages{flex:1;overflow-y:auto;padding:1rem;display:flex;flex-direction:column;gap:0.6rem}.msg{padding:0.6rem 0.85rem;border-radius:10px;max-width:85%;line-height:1.5;font-size:0.9rem}.msg.user{background:#1a1a2e;align-self:flex-start;border:1px solid #252540}.msg.agent{background:#0f1a1a;align-self:flex-end;border:1px solid #0d3d3d}.msg .who{font-size:0.65rem;color:#52525b;margin-bottom:0.2rem}.input-bar{display:flex;gap:0.5rem;padding:1rem;border-top:1px solid #1e1e2e;background:#0f0f18}.input-bar input{flex:1;padding:0.65rem 0.85rem;border-radius:8px;border:1px solid #252540;background:#141420;color:#e4e4e7;font-size:0.9rem}.input-bar button{padding:0.65rem 1.1rem;border-radius:8px;border:none;background:#00d4aa;color:#0a0a0f;font-weight:600;cursor:pointer}.panels{width:320px;border-left:1px solid #1e1e2e;background:#0f0f18;display:flex;flex-direction:column}.tabs{display:flex;border-bottom:1px solid #1e1e2e}.tab{flex:1;padding:0.6rem;font-size:0.8rem;background:#141420;border:none;color:#71717a;cursor:pointer}.tab.active{color:#00d4aa;background:#0f0f18;font-weight:600}.panel{display:none;flex:1;flex-direction:column;overflow:auto;padding:0.75rem}.panel.active{display:flex}.panel-header{display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem}.panel-header h2{font-size:0.85rem}.panel-form textarea,.panel-form input{width:100%;padding:0.5rem;border-radius:6px;border:1px solid #252540;background:#141420;color:#e4e4e7;font-size:0.85rem}.panel-form button{margin-top:0.5rem;padding:0.5rem 0.85rem;border-radius:6px;border:none;background:#00d4aa;color:#0a0a0f;font-weight:600;cursor:pointer}.panel-result{margin-top:0.75rem;padding:0.65rem;background:#141420;border:1px solid #1e1e2e;border-radius:8px;font-size:0.8rem;max-height:200px;overflow-y:auto}.history-list{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:0.5rem}.history-item{padding:0.5rem 0.65rem;background:#141420;border:1px solid #1e1e2e;border-radius:8px;font-size:0.75rem}.history-item .meta{color:#71717a}.history-item .content{color:#d4d4d8}.history-item .reply{color:#a1a1aa;margin-top:0.35rem;padding-top:0.35rem;border-top:1px solid #1e1e2e}";
}

fn default_app_js() {
 return "(function(){var apiBase=window.location.origin,m=document.getElementById('messages'),f=document.getElementById('form'),i=document.getElementById('input'),aiDot=document.getElementById('ai-dot'),aiLabel=document.getElementById('ai-label'),aiFix=document.getElementById('ai-fix');function setStatus(ok,msg){aiDot.className='ai-dot '+(ok?'connected':'disconnected');aiLabel.textContent=ok?'LLM connected':(msg||'LLM disconnected');if(ok)aiFix.classList.remove('visible');else{aiFix.classList.add('visible');aiFix.innerHTML='<strong>Setup:</strong> Set OPENAI_API_KEY in .env and restart.';}}(async function(){try{var r=await fetch(apiBase+'/api/ai-status'),d=await r.json().catch(function(){});setStatus(!!d.connected,d.message);}catch(e){setStatus(false,'Cannot reach server');}})();setInterval(function(){fetch(apiBase+'/api/ai-status').then(function(r){return r.json();}).then(function(d){setStatus(!!d.connected,d.message);}).catch(function(){setStatus(false);});},45000);function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');}function nl2br(s){return String(s).replace(/\\n/g,'<br>');}function addMsg(who,text){var d=document.createElement('div');d.className='msg '+who;d.innerHTML='<div class=\"who\">'+who+'</div><div>'+nl2br(esc(text))+'</div>';m.appendChild(d);m.scrollTop=m.scrollHeight;}f.addEventListener('submit',async function(e){e.preventDefault();var c=i.value.trim();if(!c)return;addMsg('user',c);i.value='';i.focus();try{var r=await fetch(apiBase+'/api/message',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({sender_id:'web',content:c})});var d=await r.json().catch(function(){});addMsg('agent',d.reply||d.error||(r.ok?'No reply':'Error '+r.status));}catch(err){addMsg('agent','Error: '+(err&&err.message||String(err)));}});var hList=document.getElementById('history-list'),hRef=document.getElementById('history-refresh'),hClr=document.getElementById('history-clear');function renderHist(entries){hList.innerHTML='';if(!entries||entries.length===0){hList.innerHTML='<div class=\"history-empty\">No history yet.</div>';return;}entries.forEach(function(e){var el=document.createElement('div');el.className='history-item';el.innerHTML='<div class=\"meta\">'+(e.ts||'')+' · '+(e.type||'')+' · '+esc(e.sender||'')+'</div><div class=\"content\">'+nl2br(esc((e.content||'').slice(0,200)))+'</div>'+(e.reply?'<div class=\"reply\">'+nl2br(esc((e.reply||'').slice(0,150)))+'</div>':'');hList.appendChild(el);});}async function refreshHist(){try{var r=await fetch(apiBase+'/api/history'),d=await r.json().catch(function(){});if(d.ok&&Array.isArray(d.entries))renderHist(d.entries);else renderHist([]);}catch(e){renderHist([]);}}if(hRef)hRef.addEventListener('click',refreshHist);if(hClr)hClr.addEventListener('click',async function(){if(!confirm('Clear history?'))return;await fetch(apiBase+'/api/history/clear',{method:'POST'});refreshHist();});refreshHist();var taskForm=document.getElementById('task-form'),taskIn=document.getElementById('task-input'),taskRes=document.getElementById('task-result');if(taskForm)taskForm.addEventListener('submit',async function(e){e.preventDefault();var desc=(taskIn&&taskIn.value.trim())||'';if(!desc)return;taskRes.textContent='Running…';taskRes.className='panel-result loading';try{var r=await fetch(apiBase+'/api/task',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({description:desc})});var d=await r.json().catch(function(){});taskRes.className='panel-result';taskRes.textContent=d.error?d.error:(d.result||'Done.');if(!d.error)refreshHist();}catch(err){taskRes.className='panel-result error';taskRes.textContent='Error: '+err.message;});var wfForm=document.getElementById('workflow-form'),wfSel=document.getElementById('workflow-select'),wfIn=document.getElementById('workflow-input'),wfRes=document.getElementById('workflow-result');async function loadWf(){try{var r=await fetch(apiBase+'/api/workflow/list'),d=await r.json().catch(function(){});wfSel.innerHTML='';if(d.ok&&Array.isArray(d.workflows))d.workflows.forEach(function(w){var o=document.createElement('option');o.value=w.name;o.textContent=w.name+(w.description?' — '+w.description.slice(0,40):'');wfSel.appendChild(o);});else{wfSel.innerHTML='<option value=\"\">No workflows</option>';}}catch(e){wfSel.innerHTML='<option value=\"\">Failed to load</option>';}}if(wfForm)wfForm.addEventListener('submit',async function(e){e.preventDefault();var name=wfSel.value,inp=wfIn&&wfIn.value.trim();if(!name||!inp)return;wfRes.textContent='Running…';wfRes.className='panel-result loading';try{var r=await fetch(apiBase+'/api/workflow',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({workflow:name,input:inp})});var d=await r.json().catch(function(){});wfRes.className='panel-result';wfRes.textContent=d.error?d.error:(d.final_result||'Done.');if(!d.error)refreshHist();}catch(err){wfRes.className='panel-result error';wfRes.textContent='Error: '+err.message;});loadWf();document.querySelectorAll('.tab').forEach(function(tab){tab.addEventListener('click',function(){var id=tab.getAttribute('data-panel');document.querySelectorAll('.tab').forEach(function(t){t.classList.remove('active');});document.querySelectorAll('.panel').forEach(function(p){p.classList.remove('active');});tab.classList.add('active');var p=document.getElementById('panel-'+id);if(p)p.classList.add('active');});});})();";
}

@route("GET", "/")
fn home_page(request) {
 let base = get_ui_base();
 let body = get_index_html(base);
 return {
  "status": 200,
  "headers": {
   "Content-Type": "text/html; charset=utf-8",
   "Content-Security-Policy": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src 'self'"
  },
  "body": body
 };
}

@route("GET", "/favicon.ico")
fn favicon(request) {
 return {"status": 204, "headers": {}, "body": ""};
}

@route("GET", "/styles.css")
fn styles_css(request) {
 let base = get_ui_base();
 let body = get_styles_css(base);
 return {
  "status": 200,
  "headers": {"Content-Type": "text/css; charset=utf-8"},
  "body": body
 };
}

@route("GET", "/app.js")
fn app_js(request) {
 let base = get_ui_base();
 let body = get_app_js(base);
 return {
  "status": 200,
  "headers": {"Content-Type": "application/javascript; charset=utf-8"},
  "body": body
 };
}

// ---------------------------------------------------------------------------
// Health / diagnostics
// ---------------------------------------------------------------------------

@route("GET", "/health")
fn health(request) {
 return {
  "status": 200,
  "headers": {"Content-Type": "application/json"},
  "body": "{\"status\":\"ok\",\"service\":\"agent-assistant\",\"version\":\"0.2.0\"}"
 };
}

@route("GET", "/api/status")
fn api_status(request) {
 let server_metrics = get_metrics();

 let runtime = load_agent_runtime();
 let agent_count = 0;
 let serve_agent = "";
 let agent_info = null;
 if (runtime != null) {
  serve_agent = runtime["serve_agent_id"];
  if (serve_agent == null) {
   serve_agent = "";
  }
  let contexts = runtime["agent_contexts"];
  if (contexts != null) {
   // Count agents via the runtime file
   try {
    let count_str = sh::run("cat .dal/agent_runtime.json | python3 -c \"import sys,json; print(len(json.load(sys.stdin).get('agent_contexts',{})))\" 2>/dev/null");
    if (count_str != null && len(count_str) > 0) {
     agent_count = to_int(count_str);
    }
   } catch {
    agent_count = 0;
   }
   // Get serve agent details
   if (len(serve_agent) > 0 && contexts[serve_agent] != null) {
    let ctx = contexts[serve_agent];
    let cfg = ctx["config"];
    let perf = ctx["performance_metrics"];
    agent_info = {
     "agent_id": serve_agent,
     "name": cfg["name"],
     "type": cfg["agent_type"],
     "role": cfg["role"],
     "status": ctx["status"],
     "skills": cfg["skills"],
     "trust_score": ctx["trust_score"],
     "metrics": perf
    };
   }
  }
 }

 let ctx_len = 0;
 let ctx = load_context();
 if (ctx != null) {
  ctx_len = len(ctx);
 }

 let out = {
  "ok": true,
  "version": "0.2.0",
  "server": server_metrics,
  "agent_count": agent_count,
  "serve_agent": agent_info,
  "context_length": ctx_len
 };
 return {
  "status": 200,
  "headers": {"Content-Type": "application/json"},
  "body": json::stringify(out)
 };
}

@route("GET", "/api/debug-ai")
fn api_debug_ai(request) {
 let reply = ai::generate_text(".");
 let rlen = 0;
 if (reply != null) {
  rlen = len(reply);
 }
 let out = {"ok": true, "reply_len": rlen, "reply": reply};
 return {
  "status": 200,
  "headers": {"Content-Type": "application/json"},
  "body": json::stringify(out)
 };
}

@route("GET", "/api/diag")
fn api_diag(request) {
 try {
  let reply = ai::generate_text(".");
  let is_placeholder = (reply == "Generated response to: .");
  let rlen = 0;
  if (reply != null) {
   rlen = len(reply);
  }
  let out = {"status": "ok", "is_placeholder": is_placeholder, "reply_len": rlen};
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": json::stringify(out)
  };
 } catch {
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"status\":\"error\",\"message\":\"ai::generate_text threw\"}"
  };
 }
}

@route("GET", "/api/ai-status")
fn api_ai_status(request) {
 try {
  let reply = ai::generate_text(".");
  let ok = (reply != null && len(reply) > 0);
  if (!ok) {
   return {
    "status": 200,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"connected\":false,\"message\":\"LLM disconnected\"}"
   };
  }
  let is_placeholder = (reply == "Generated response to: .");
  if (is_placeholder) {
   return {
    "status": 200,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"connected\":false,\"message\":\"LLM disconnected (placeholder)\"}"
   };
  }
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"connected\":true,\"message\":\"LLM connected\"}"
  };
 } catch {
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"connected\":false,\"message\":\"LLM disconnected (error)\"}"
  };
 }
}

// ---------------------------------------------------------------------------
// Context endpoint — see what the agent remembers
// ---------------------------------------------------------------------------

@route("GET", "/api/context")
fn api_context(request) {
 let ctx = load_context();
 let ctx_len = 0;
 if (ctx != null) {
  ctx_len = len(ctx);
 }
 let out = {"ok": true, "context_length": ctx_len, "context": ctx};
 return {
  "status": 200,
  "headers": {"Content-Type": "application/json"},
  "body": json::stringify(out)
 };
}

// ---------------------------------------------------------------------------
// POST /api/message — Chat with evolve memory
// ---------------------------------------------------------------------------

@route("POST", "/api/message")
fn api_message(request) {
 try {
  let body_str = request.body;
  if (body_str == null) {
   body_str = "";
  }
  if (len(body_str) == 0) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"Missing body\"}"
   };
  }
  let body = json::parse(body_str);
  let content = body["content"];
  let sender_id = body["sender_id"];
  if (content == null) {
   content = body["text"];
  }
  if (content == null) {
   content = "";
  }
  if (sender_id == null) {
   sender_id = "web";
  }

  metrics_messages = metrics_messages + 1;
  log::info("message", "from:" + sender_id + " len:" + to_string(len(content)));

  // Build context-enriched prompt so the LLM sees recent memory
  let enriched = enrich_prompt(content);

  let reply = "";
  try {
   reply = ai::respond_with_tools(enriched);
  } catch {
   reply = "AI is not configured. See README for setup.";
  }
  if (reply == null || len(reply) == 0) {
   reply = "No response. See README for setup.";
  }

  // Persist this exchange to evolve memory and history
  log_conversation(content, reply);
  history_append(sender_id, content, reply, "message");
  log_action("message", "from:" + sender_id, "replied");
  log::info("message", "replied to:" + sender_id + " len:" + to_string(len(reply)));
  trim_context();
  history_trim();

  let out = {"reply": reply, "sender_id": sender_id};
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": json::stringify(out)
  };
 } catch {
  metrics_errors = metrics_errors + 1;
  log::info("message", "error: server error");
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"reply\":\"Server error. Send JSON with content or text.\",\"sender_id\":\"web\"}"
  };
 }
}

// ---------------------------------------------------------------------------
// POST /api/task — Task execution with evolve memory
// ---------------------------------------------------------------------------

@route("POST", "/api/task")
fn api_task(request) {
 try {
  let body_str = request.body;
  if (body_str == null || len(body_str) == 0) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"Missing body\"}"
   };
  }
  let body = json::parse(body_str);
  let description = body["description"];
  if (description == null) {
   description = body["task"];
  }
  if (description == null) {
   description = "";
  }

  metrics_tasks = metrics_tasks + 1;
  log::info("task", "started: " + description);

  let enriched = enrich_prompt(description);

  let result = "";
  try {
   result = ai::respond_with_tools(enriched);
  } catch {
   result = "AI is not configured. See README for setup.";
  }
  if (result == null || len(result) == 0) {
   result = "No result.";
  }

  log_conversation(description, result);
  history_append("task", description, result, "task");
  log_action("task", description, "completed");
  log::info("task", "completed: " + description);
  trim_context();
  history_trim();

  let out = {"ok": true, "task": description, "result": result};
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": json::stringify(out)
  };
 } catch {
  return {
   "status": 500,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"error\":\"Task execution failed\"}"
  };
 }
}

// ---------------------------------------------------------------------------
// POST /api/context/summary — Summarize and compress context
// ---------------------------------------------------------------------------

@route("POST", "/api/context/summary")
fn api_context_summary(request) {
 try {
  let ctx = load_context();
  if (ctx == null || len(ctx) == 0) {
   return {
    "status": 200,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"ok\":true,\"message\":\"No context to summarize\"}"
   };
  }
  let summary = "";
  try {
   summary = ai::generate_text("Summarize the following agent context into a concise paragraph. Keep key facts, decisions, and user preferences. Drop routine greetings.\n\n" + ctx);
  } catch {
   summary = "Could not generate summary (AI not configured).";
  }
  evolve::append_summary(summary, "auto-summary");
  trim_context();
  let out = {"ok": true, "summary": summary};
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": json::stringify(out)
  };
 } catch {
  return {
   "status": 500,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"error\":\"Summary failed\"}"
  };
 }
}

// ---------------------------------------------------------------------------
// GET /api/history — Retrieve conversation history
// Query: ?limit=50 (default 50, max 500)
// ---------------------------------------------------------------------------

@route("GET", "/api/history")
fn api_history(request) {
 let limit = 50;
 // DAL route handlers don't parse query params natively, use default
 let entries = history_read(limit);
 let count = history_count();
 let out_str = "{\"ok\":true,\"total\":" + to_string(count) + ",\"showing\":" + to_string(limit) + ",\"entries\":" + entries + "}";
 return {
  "status": 200,
  "headers": {"Content-Type": "application/json"},
  "body": out_str
 };
}

// ---------------------------------------------------------------------------
// POST /api/history/clear — Clear conversation history
// ---------------------------------------------------------------------------

@route("POST", "/api/history/clear")
fn api_history_clear(request) {
 try {
  sh::run("rm -f " + HISTORY_FILE);
  log::info("history", "cleared");
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"ok\":true,\"message\":\"History cleared\"}"
  };
 } catch {
  return {
   "status": 500,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"error\":\"Failed to clear history\"}"
  };
 }
}

