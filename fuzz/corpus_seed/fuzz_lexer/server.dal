// ---------------------------------------------------------------------------
// POST /api/workflow — Execute a workflow
// Body: { "workflow": "research_and_summarize", "input": "topic or task" }
// ---------------------------------------------------------------------------

@route("POST", "/api/workflow")
fn api_workflow(request) {
 try {
  let body_str = request.body;
  if (body_str == null || len(body_str) == 0) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"Missing body\"}"
   };
  }
  let body = json::parse(body_str);
  let workflow_name = body["workflow"];
  let input = body["input"];
  if (workflow_name == null || input == null) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"workflow and input are required\"}"
   };
  }

  log::info("workflow", "API run: " + workflow_name + " input: " + input);
  log::audit("workflow", workflow_name + ": " + input);
  let result = workflows::run(workflow_name, input);

  // Log to history
  history_append("workflow:" + workflow_name, input, result["final_result"], "workflow");

  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": json::stringify(result)
  };
 } catch {
  metrics_errors = metrics_errors + 1;
  return {
   "status": 500,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"error\":\"Workflow execution failed\"}"
  };
 }
}

// ---------------------------------------------------------------------------
// POST /api/workflow/define — Save a custom workflow
// Body: {
//   "name": "my_workflow",
//   "description": "What this workflow does",
//   "steps": [
//     {"role": "researcher", "prompt": "Research {input}"},
//     {"role": "coder", "prompt": "Write code based on: {prev}"},
//     {"role": "reviewer", "prompt": "Review: {prev}"}
//   ]
// }
// Placeholders: {input} = original user input, {prev} = previous step output
// ---------------------------------------------------------------------------

@route("POST", "/api/workflow/define")
fn api_workflow_define(request) {
 try {
  let body_str = request.body;
  if (body_str == null || len(body_str) == 0) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"Missing body\"}"
   };
  }
  let body = json::parse(body_str);
  let name = body["name"];
  let steps = body["steps"];
  if (name == null || steps == null) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"name and steps are required\"}"
   };
  }
  // Reject overwriting built-ins
  if (name == "research_and_summarize" || name == "code_and_review" || name == "deep_research") {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"Cannot override built-in workflow\"}"
   };
  }

  let description = body["description"];
  if (description == null) {
   description = "Custom workflow";
  }

  let definition = {"steps": steps, "description": description};
  let saved = workflows::save_custom(name, definition);
  if (saved) {
   log::audit("workflow", "Defined custom: " + name);
   let out = {"ok": true, "name": name, "description": description, "message": "Workflow saved"};
   return {
    "status": 200,
    "headers": {"Content-Type": "application/json"},
    "body": json::stringify(out)
   };
  }
  return {
   "status": 500,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"error\":\"Failed to save workflow\"}"
  };
 } catch {
  return {
   "status": 500,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"error\":\"Define failed\"}"
  };
 }
}

// ---------------------------------------------------------------------------
// POST /api/workflow/delete — Delete a custom workflow
// Body: { "name": "my_workflow" }
// ---------------------------------------------------------------------------

@route("POST", "/api/workflow/delete")
fn api_workflow_delete(request) {
 try {
  let body_str = request.body;
  if (body_str == null || len(body_str) == 0) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"Missing body\"}"
   };
  }
  let body = json::parse(body_str);
  let name = body["name"];
  if (name == null) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"name is required\"}"
   };
  }
  let deleted = workflows::delete_custom(name);
  log::audit("workflow", "Deleted custom: " + name);
  let out = {"ok": true, "name": name, "message": "Workflow deleted"};
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": json::stringify(out)
  };
 } catch {
  return {
   "status": 500,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"error\":\"Delete failed\"}"
  };
 }
}

// ---------------------------------------------------------------------------
// POST /api/send — Send outbound message to a channel
// Body: { "channel": "telegram|discord|imessage", "recipient": "chat_id", "message": "text" }
// ---------------------------------------------------------------------------

@route("POST", "/api/send")
fn api_send(request) {
 try {
  let body_str = request.body;
  if (body_str == null || len(body_str) == 0) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"Missing body\"}"
   };
  }
  let body = json::parse(body_str);
  let channel = body["channel"];
  let recipient = body["recipient"];
  let message = body["message"];
  if (channel == null || message == null) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"channel and message are required\"}"
   };
  }
  if (recipient == null) {
   recipient = "";
  }
  metrics_sends = metrics_sends + 1;
  log::audit("send", "channel:" + channel + " recipient:" + recipient + " len:" + to_string(len(message)));
  let result = comms::send(channel, recipient, message);
  log_action("send", channel + ":" + recipient, "sent");
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": json::stringify(result)
  };
 } catch {
  metrics_errors = metrics_errors + 1;
  log::info("send", "error: send failed");
  return {
   "status": 500,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"error\":\"Send failed\"}"
  };
 }
}

// ---------------------------------------------------------------------------
// POST /api/reply — Reply through the originating channel
// Body: { "sender_id": "telegram_123", "message": "text" }
// ---------------------------------------------------------------------------

@route("POST", "/api/reply")
fn api_reply(request) {
 try {
  let body_str = request.body;
  if (body_str == null || len(body_str) == 0) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"Missing body\"}"
   };
  }
  let body = json::parse(body_str);
  let sender_id = body["sender_id"];
  let message = body["message"];
  if (sender_id == null || message == null) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"sender_id and message are required\"}"
   };
  }
  log::audit("reply", "to:" + sender_id + " len:" + to_string(len(message)));
  let result = comms::reply_to_sender(sender_id, message);
  log_action("reply", sender_id, "replied");
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": json::stringify(result)
  };
 } catch {
  metrics_errors = metrics_errors + 1;
  log::info("reply", "error: reply failed");
  return {
   "status": 500,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"error\":\"Reply failed\"}"
  };
 }
}

