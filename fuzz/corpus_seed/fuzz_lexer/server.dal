   "body": json::stringify(result)
  };
 } catch {
  metrics_errors = metrics_errors + 1;
  return {
   "status": 500,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"error\":\"Agent run failed\"}"
  };
 }
}

