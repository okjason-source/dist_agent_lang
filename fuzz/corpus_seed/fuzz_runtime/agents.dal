// Multi-agent module — spawn, coordinate, and manage specialized sub-agents.
//
// Agents:
//   researcher — search-heavy tasks, information gathering
//   coder      — code generation, scripting, file operations
//   reviewer   — review output, check quality, summarize
//
// Usage from server.dal:
//   import "./agents.dal" as agents;
//   let rid = agents::spawn_researcher();
//   agents::assign(rid, "research latest DAL features");
//   let result = agents::get_result(rid);
import stdlib::agent;

let spawned_agents = {};

fn spawn_researcher() {
 let agent_id = agent::spawn({
  "name": "researcher",
  "type": "ai",
  "role": "Research agent — search the web, gather information, compile findings",
  "capabilities": ["task_execution", "communication", "learning"]
 });
 spawned_agents["researcher"] = agent_id;
 log::info("agents", "Spawned researcher: " + agent_id);
 return agent_id;
}

fn spawn_coder() {
 let agent_id = agent::spawn({
  "name": "coder",
  "type": "ai",
  "role": "Code agent — write code, run scripts, create files, test programs",
  "capabilities": ["task_execution", "automation", "problem_solving"]
 });
 spawned_agents["coder"] = agent_id;
 log::info("agents", "Spawned coder: " + agent_id);
 return agent_id;
}

fn spawn_reviewer() {
 let agent_id = agent::spawn({
  "name": "reviewer",
  "type": "ai",
  "role": "Review agent — check quality, verify results, provide feedback, summarize",
  "capabilities": ["analysis", "communication", "learning"]
 });
 spawned_agents["reviewer"] = agent_id;
 log::info("agents", "Spawned reviewer: " + agent_id);
 return agent_id;
}

fn get_or_spawn(role) {
 if (role == "researcher") {
  if (spawned_agents["researcher"] != null) {
   return spawned_agents["researcher"];
  }
  return spawn_researcher();
 }
 if (role == "coder") {
  if (spawned_agents["coder"] != null) {
   return spawned_agents["coder"];
  }
  return spawn_coder();
 }
 if (role == "reviewer") {
  if (spawned_agents["reviewer"] != null) {
   return spawned_agents["reviewer"];
  }
  return spawn_reviewer();
 }
 return null;
}

fn assign(agent_id, task_description) {
 try {
  let result = agent::coordinate(agent_id, task_description, "task_distribution");
  log::info("agents", "Assigned to " + agent_id + ": " + task_description);
  return result;
 } catch {
  log::info("agents", "Assign failed for " + agent_id);
  return null;
 }
}

fn send_message(from_id, to_id, content) {
 try {
  let result = agent::communicate(from_id, to_id, content);
  log::info("agents", "Message " + from_id + " -> " + to_id);
  return result;
 } catch {
  return null;
 }
}

fn status(agent_id) {
 try {
  return agent::get_status(agent_id);
 } catch {
  return "unknown";
 }
}

fn list_agents() {
 return spawned_agents;
}

fn run_with_agent(role, task, include_rag) {
 let agent_id = get_or_spawn(role);
 if (agent_id == null) {
  return {"ok": false, "error": "Unknown role: " + role};
 }

 // Assign the task via coordination
 assign(agent_id, task);

 // Execute via LLM with role-specific system prompt
 let role_prompt = "";
 if (role == "researcher") {
  role_prompt = "You are a research agent. Focus on searching for information, gathering data, and compiling findings. Use search when you need external information. Be thorough and cite sources when possible.\n\n";
 }
 if (role == "coder") {
  role_prompt = "You are a code agent. Focus on writing clean, working code. Use run to test your code. Create files when needed. Be precise and handle errors.\n\n";
 }
 if (role == "reviewer") {
  role_prompt = "You are a review agent. Analyze the provided content for quality, correctness, and completeness. Provide specific feedback and a summary.\n\n";
 }

 let result = "";
 try {
  result = ai::respond_with_tools(role_prompt + "Task: " + task);
 } catch {
  result = "Agent " + role + " failed to execute task.";
 }

 log::info("agents", role + " completed: " + task);
 log::audit("agents", role + ":" + agent_id + " task:" + task);
 return {"ok": true, "role": role, "agent_id": agent_id, "result": result};
}
