// Workflow engine — chain agents together for multi-step tasks.
//
// Built-in workflows:
//   research_and_summarize — researcher gathers info, reviewer summarizes
//   code_and_review        — coder writes code, reviewer checks quality
//   deep_research          — researcher searches, coder runs commands, reviewer compiles
//
// Custom workflows:
//   Define via POST /api/workflow/define with a steps array.
//   Each step has a "role" and "prompt" (use {input} for user input, {prev} for previous output).
//   Saved to custom_workflows.json and runnable by name.
//
// Usage:
//   import "./workflows.dal" as wf;
//   let result = wf::run("research_and_summarize", "latest trends in AI agents");
import "./agents.dal" as agents;

let CUSTOM_FILE = "custom_workflows.json";

// ---------------------------------------------------------------------------
// Run dispatcher — checks built-in, then custom, then ad-hoc
// ---------------------------------------------------------------------------

fn run(workflow_name, input) {
 log::info("workflow", "Starting: " + workflow_name);

 if (workflow_name == "research_and_summarize") {
  return research_and_summarize(input);
 }
 if (workflow_name == "code_and_review") {
  return code_and_review(input);
 }
 if (workflow_name == "deep_research") {
  return deep_research(input);
 }

 // Check custom workflows
 let custom = load_custom(workflow_name);
 if (custom != null) {
  return run_custom(workflow_name, custom, input);
 }

 // Unknown workflow — run as ad-hoc single-agent task
 let result = agents::run_with_agent("researcher", input);
 return {
  "ok": true,
  "workflow": workflow_name,
  "steps": [result],
  "final_result": result["result"]
 };
}

// ---------------------------------------------------------------------------
// Built-in workflows
// ---------------------------------------------------------------------------

fn research_and_summarize(topic) {
 let step1 = agents::run_with_agent("researcher", "Research the following topic thoroughly. Search for current information and compile your findings.\n\nTopic: " + topic);

 let findings = step1["result"];
 if (findings == null) {
  findings = "No research results available.";
 }
 let step2 = agents::run_with_agent("reviewer", "Summarize the following research findings into a clear, concise report. Highlight key points and actionable insights.\n\nFindings:\n" + findings);

 log::info("workflow", "Completed: research_and_summarize");
 return {
  "ok": true,
  "workflow": "research_and_summarize",
  "topic": topic,
  "steps": [
   {"role": "researcher", "result": step1["result"]},
   {"role": "reviewer", "result": step2["result"]}
  ],
  "final_result": step2["result"]
 };
}

fn code_and_review(task) {
 let step1 = agents::run_with_agent("coder", "Write code for the following task. Include error handling and make it production-ready.\n\nTask: " + task);

 let code = step1["result"];
 if (code == null) {
  code = "No code generated.";
 }
 let step2 = agents::run_with_agent("reviewer", "Review the following code for correctness, edge cases, security issues, and style. Provide specific feedback and a quality rating (1-10).\n\nCode:\n" + code);

 log::info("workflow", "Completed: code_and_review");
 return {
  "ok": true,
  "workflow": "code_and_review",
  "task": task,
  "steps": [
   {"role": "coder", "result": step1["result"]},
   {"role": "reviewer", "result": step2["result"]}
  ],
  "final_result": step1["result"] + "\n\n--- Review ---\n\n" + step2["result"]
 };
}

fn deep_research(topic) {
 let step1 = agents::run_with_agent("researcher", "Search for information about: " + topic + ". Gather key facts, recent developments, and relevant data.");

 let findings = step1["result"];
 if (findings == null) {
  findings = "";
 }
 let step2 = agents::run_with_agent("coder", "Based on these research findings, run any useful commands to gather additional data (e.g., check package versions, list directories, fetch URLs). Return what you find.\n\nInitial findings:\n" + findings);

 let extra = step2["result"];
 if (extra == null) {
  extra = "";
 }
 let combined = findings + "\n\n" + extra;
 let step3 = agents::run_with_agent("reviewer", "Compile the following research into a comprehensive, well-structured report. Include sections for overview, key findings, data, and recommendations.\n\nResearch data:\n" + combined);

 log::info("workflow", "Completed: deep_research");
 return {
  "ok": true,
  "workflow": "deep_research",
  "topic": topic,
  "steps": [
   {"role": "researcher", "result": step1["result"]},
   {"role": "coder", "result": step2["result"]},
   {"role": "reviewer", "result": step3["result"]}
  ],
  "final_result": step3["result"]
 };
}

// ---------------------------------------------------------------------------
// Custom workflow engine
// ---------------------------------------------------------------------------

fn run_custom(workflow_name, definition, input) {
 let steps_def = definition["steps"];
 if (steps_def == null) {
  return {"ok": false, "error": "Workflow has no steps"};
 }

 let step_results = [];
 let prev_output = "";
 let step_count = 0;

 // Count steps via python (DAL arrays don't have a native length method on parsed JSON arrays)
 try {
  let count_str = sh::run("echo '" + json::stringify(steps_def) + "' | python3 -c \"import sys,json; print(len(json.load(sys.stdin)))\"");
  if (count_str != null && len(count_str) > 0) {
   step_count = to_int(count_str);
  }
 } catch {
  step_count = 0;
 }

 // Execute each step sequentially
 let final_result = "";
 try {
  // Extract and run steps via python to handle JSON array iteration
  let steps_json = json::stringify(steps_def);
  let runner_script = "import sys,json\nsteps=json.load(sys.stdin)\nfor i,s in enumerate(steps):\n    print(json.dumps(s))";
  let step_lines = sh::run("echo '" + steps_json + "' | python3 -c \"" + runner_script + "\"");

  if (step_lines != null && len(step_lines) > 0) {

   // For each step index, extract role and prompt, run the agent
   fn run_step_at(steps_j, index, user_input, previous) {
    let extract = sh::run("echo '" + steps_j + "' | python3 -c \"import sys,json; s=json.load(sys.stdin)[" + to_string(index) + "]; print(s.get('role','researcher')); print('---SEP---'); print(s.get('prompt','{input}'))\"");
    if (extract == null || len(extract) == 0) {
     return null;
    }
    // Parse role and prompt from output
    let parts_role = sh::run("echo '" + extract + "' | head -1");
    let parts_prompt = sh::run("echo '" + extract + "' | sed '1,/---SEP---/d'");

    if (parts_role == null) {
     parts_role = "researcher";
    }
    if (parts_prompt == null) {
     parts_prompt = user_input;
    }

    // Replace {input} and {prev} placeholders
    let resolved = sh::run("printf '%s' '" + parts_prompt + "' | sed 's/{input}/" + sh::run("printf '%s' '" + user_input + "' | sed 's/[&/\\\\]/\\\\&/g' | head -c 2000") + "/g'");
    if (previous != null && len(previous) > 0) {
     let prev_safe = sh::run("printf '%s' '" + previous + "' | sed 's/[&/\\\\]/\\\\&/g' | head -c 2000");
     resolved = sh::run("printf '%s' '" + resolved + "' | sed 's/{prev}/" + prev_safe + "/g'");
    }

    // Clean role (trim whitespace)
    parts_role = sh::run("echo -n '" + parts_role + "'");

    let step_result = agents::run_with_agent(parts_role, resolved);
    return step_result;
   }

   // Iterate over steps
   let s0 = null;
   let s1 = null;
   let s2 = null;
   let s3 = null;
   let s4 = null;

   if (step_count > 0) {
    s0 = run_step_at(steps_json, 0, input, "");
    if (s0 != null) {
     prev_output = s0["result"];
     step_results = [{"role": s0["role"], "result": s0["result"]}];
     final_result = s0["result"];
    }
   }
   if (step_count > 1) {
    s1 = run_step_at(steps_json, 1, input, prev_output);
    if (s1 != null) {
     prev_output = s1["result"];
     step_results = [step_results[0], {"role": s1["role"], "result": s1["result"]}];
     final_result = s1["result"];
    }
   }
   if (step_count > 2) {
    s2 = run_step_at(steps_json, 2, input, prev_output);
    if (s2 != null) {
     prev_output = s2["result"];
     step_results = [step_results[0], step_results[1], {"role": s2["role"], "result": s2["result"]}];
     final_result = s2["result"];
    }
   }
   if (step_count > 3) {
    s3 = run_step_at(steps_json, 3, input, prev_output);
    if (s3 != null) {
     prev_output = s3["result"];
     final_result = s3["result"];
    }
   }
   if (step_count > 4) {
    s4 = run_step_at(steps_json, 4, input, prev_output);
    if (s4 != null) {
     final_result = s4["result"];
    }
   }
  }
 } catch {
  log::info("workflow", "Custom workflow step execution error");
 }

 if (final_result == null || len(final_result) == 0) {
  final_result = "Workflow produced no output.";
 }

 log::info("workflow", "Completed custom: " + workflow_name + " (" + to_string(step_count) + " steps)");
 return {
  "ok": true,
  "workflow": workflow_name,
  "custom": true,
  "step_count": step_count,
  "steps": step_results,
  "final_result": final_result
 };
}

// ---------------------------------------------------------------------------
// Custom workflow persistence (JSON file)
// ---------------------------------------------------------------------------

fn save_custom(name, definition) {
 try {
  // Load existing definitions
  let existing = load_all_custom();
  // Add/update this workflow via python
  let def_json = json::stringify(definition);
  let existing_json = "{}";
  if (existing != null) {
   existing_json = json::stringify(existing);
  }
  sh::run("python3 -c \"import json; d=json.loads('" + existing_json + "'); d['" + name + "']=" + def_json + "; open('" + CUSTOM_FILE + "','w').write(json.dumps(d,indent=2))\"");
  log::info("workflow", "Saved custom workflow: " + name);
  return true;
 } catch {
  log::info("workflow", "Failed to save custom workflow: " + name);
  return false;
 }
}

fn load_custom(name) {
 try {
  let raw = sh::run("cat " + CUSTOM_FILE + " 2>/dev/null");
  if (raw == null || len(raw) == 0) {
   return null;
  }
  let all = json::parse(raw);
  return all[name];
 } catch {
  return null;
 }
}

fn load_all_custom() {
 try {
  let raw = sh::run("cat " + CUSTOM_FILE + " 2>/dev/null");
  if (raw == null || len(raw) == 0) {
   return {};
  }
  return json::parse(raw);
 } catch {
  return {};
 }
}

fn delete_custom(name) {
 try {
  let existing = load_all_custom();
  sh::run("python3 -c \"import json; d=json.loads('" + json::stringify(existing) + "'); d.pop('" + name + "',None); open('" + CUSTOM_FILE + "','w').write(json.dumps(d,indent=2))\"");
  log::info("workflow", "Deleted custom workflow: " + name);
  return true;
 } catch {
  return false;
 }
}

// ---------------------------------------------------------------------------
// Listing (built-in + custom)
// ---------------------------------------------------------------------------

fn list_workflows() {
 let builtins = [
  {"name": "research_and_summarize", "steps": ["researcher", "reviewer"], "description": "Research a topic and produce a summary report", "custom": false},
  {"name": "code_and_review", "steps": ["coder", "reviewer"], "description": "Write code and review it for quality", "custom": false},
  {"name": "deep_research", "steps": ["researcher", "coder", "reviewer"], "description": "Multi-agent deep research with data gathering and compilation", "custom": false}
 ];

 // Append custom workflow names
 let custom_list = [];
 try {
  let names_str = sh::run("cat " + CUSTOM_FILE + " 2>/dev/null | python3 -c \"import sys,json; d=json.load(sys.stdin); [print(json.dumps({'name':k,'steps':[s.get('role','?') for s in v.get('steps',[])],'description':v.get('description','Custom workflow'),'custom':True})) for k,v in d.items()]\"");
  if (names_str != null && len(names_str) > 0) {
   custom_list = sh::run("cat " + CUSTOM_FILE + " 2>/dev/null | python3 -c \"import sys,json; d=json.load(sys.stdin); print(json.dumps([{'name':k,'steps':[s.get('role','?') for s in v.get('steps',[])],'description':v.get('description','Custom workflow'),'custom':True} for k,v in d.items()]))\"");
   if (custom_list != null && len(custom_list) > 0) {
    // Return combined as JSON string for the endpoint to use
    let combined = sh::run("python3 -c \"import json; b=" + json::stringify(builtins) + "; c=" + custom_list + "; print(json.dumps(b+c))\"");
    if (combined != null && len(combined) > 0) {
     return json::parse(combined);
    }
   }
  }
 } catch {
  // no custom workflows
 }

 return builtins;
}
