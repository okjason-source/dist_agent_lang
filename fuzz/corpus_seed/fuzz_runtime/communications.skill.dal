# Communications skill — send and receive messages across channels.
#
# Channels: Telegram, Discord, iMessage (macOS).
# Inbound: bridge/index.js listens for messages and POSTs to /api/message.
# Outbound: agent uses sh::run + curl (Telegram/Discord API) or osascript (iMessage).
#
# The agent can proactively send messages when a task result is ready,
# or reply through the originating channel.

skill "communications" {
  category "office"
  description "Send and receive messages via Telegram, Discord, and iMessage. Use 'run' to send outbound messages through channel APIs. Inbound messages arrive via the bridge and POST /api/message with a sender_id like telegram_123, discord_456, or imessage_+1555. When replying, match the originating channel."
  tools "run" "search"
}
