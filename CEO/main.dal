// Agent Assistant — CLI entry point
// Run: dal run main.dal
// Sends a single prompt to the agent (with evolve context) and prints the reply.
// For the full HTTP server, use: dal serve server.dal --port 4040

fn main() {
    let ctx = "";
    try {
        ctx = evolve::load();
    } catch {
        // no context yet
    }

    print("Agent Assistant v0.2.0");
    print("Context loaded: " + to_string(len(ctx)) + " chars");
    print("---");

    let prompt = "What can you do? List your capabilities briefly.";
    let enriched = prompt;
    if (ctx != null && len(ctx) > 0) {
        enriched = "## Context\n\n" + ctx + "\n\n---\n\n" + prompt;
    }

    let reply = "";
    let route = "";
    let tool_steps_count = 0;
    let policy = "";
    let termination_reason = "";
    let guard_stopped = false;
    try {
        let ai_result = ai::agent_run({"message": enriched});
        if (ai_result != null) {
            reply = ai_result["final_text"];
            route = ai_result["route"];
            tool_steps_count = ai_result["steps_used"];
            policy = ai_result["policy"];
            termination_reason = ai_result["termination_reason"];
            if (ai_result["guard_stopped"] != null) {
                guard_stopped = ai_result["guard_stopped"];
            }
        }
    } catch {
        reply = "AI not configured. Set OPENAI_API_KEY in .env and run: export $(grep -v '^#' .env | xargs) && dal run main.dal";
    }

    if (route != null && len(route) > 0) {
        print("route: " + route + " | policy: " + policy + " | tool_steps: " + to_string(tool_steps_count) + " | termination: " + termination_reason + " | guard_stopped: " + to_string(guard_stopped));
        print("---");
    }
    print(reply);
}

main();
