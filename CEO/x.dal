// X (Twitter) module — post and reply via API v2.
// Uses scripts/x_post.py only for OAuth 1.0a signing; orchestration and rules in DAL.
//
// Env: X_API_KEY, X_API_SECRET, X_ACCESS_TOKEN, X_ACCESS_TOKEN_SECRET (see .env.example).
// Usage: import "./x.dal" as x; x::send_x("Hello from DAL"); x::reply_x("123456", "Reply text").

let X_MAX_LEN = 280;
let X_SCRIPT = "scripts/x_post.py";
let X_TEMP = "/tmp/x_dal_tweet.txt";
// Prefer venv Python (has requests_oauthlib); fallback to system python3
let X_PYTHON = sh::run("test -x venv/bin/python3 && echo -n venv/bin/python3 || echo -n python3");

// Write text to temp file via heredoc (safe for any content). Optionally trim to 280 in DAL.
// Use literal path so shell commands work even when module scope is not active (e.g. agent/bridge).
fn write_temp_text(text) {
 let tmp = "/tmp/x_dal_tweet.txt";
 let seed = sh::run("date +%s%N 2>/dev/null || date +%s");
 let delim = "XDAL_" + seed + "_END";
 sh::run("cat > " + tmp + " << '" + delim + "'\n" + text + "\n" + delim);
 if (len(text) > X_MAX_LEN) {
  sh::run("head -c 277 " + tmp + " > " + tmp + ".t 2>/dev/null; echo -n '...' >> " + tmp + ".t; mv " + tmp + ".t " + tmp);
 }
 return tmp;
}

fn sh_stdout(res) {
 if (res == null) { return ""; }
 if (type(res) == "map" && res["stdout"] != null) {
  return res["stdout"];
 }
 return to_string(res);
}

// Post a new tweet. Trims to 280 chars in DAL. Returns {ok, tweet_id} or {ok: false, error}.
fn send_x(text) {
 let key = "";
 try {
  key = config::get_env("X_API_KEY");
 } catch {
  return {"ok": false, "error": "X_API_KEY not set (add X credentials to .env)"};
 }
 if (key == null || len(key) == 0) {
  return {"ok": false, "error": "X_API_KEY not set (add X credentials to .env)"};
 }
 if (text == null || len(text) == 0) {
  return {"ok": false, "error": "Empty tweet text"};
 }
 write_temp_text(text);
 let raw = "";
 try {
  raw = sh::run(X_PYTHON + " " + X_SCRIPT + " - < /tmp/x_dal_tweet.txt");
 } catch {
  return {"ok": false, "error": "x_post.py failed (check requests_oauthlib: pip install requests_oauthlib)"};
 }
 let out = sh_stdout(raw);
 if (out == null || len(out) == 0) {
  return {"ok": false, "error": "No output from x_post.py"};
 }
 try {
  let parsed = json::parse(out);
  if (parsed["ok"] == true) {
   log::audit("x:post", "tweet_id:" + to_string(parsed["tweet_id"]));
   return {"ok": true, "channel": "x", "tweet_id": parsed["tweet_id"], "result": out};
  }
  return {"ok": false, "error": parsed["error"]};
 } catch {
  return {"ok": false, "error": "Invalid JSON from x_post: " + out};
 }
}

// Batch post tweets with rate limits. Body: { "tweets": ["...", "..."], "max_per_batch": 5?, "delay_seconds": 2? }.
// max_per_batch capped at 10; delay_seconds 0..60. Returns { ok, posted: [{text, tweet_id}], failed: [{text, error}], total_requested, total_posted }.
fn send_x_batch(body) {
 if (body == null) {
  return {"ok": false, "error": "body required", "posted": [], "failed": [], "total_requested": 0, "total_posted": 0};
 }
 let tweets = body["tweets"];
 if (tweets == null) {
  return {"ok": false, "error": "tweets array required", "posted": [], "failed": [], "total_requested": 0, "total_posted": 0};
 }
 let key = "";
 try {
  key = config::get_env("X_API_KEY");
 } catch {
  return {"ok": false, "error": "X_API_KEY not set", "posted": [], "failed": [], "total_requested": 0, "total_posted": 0};
 }
 if (key == null || len(key) == 0) {
  return {"ok": false, "error": "X_API_KEY not set", "posted": [], "failed": [], "total_requested": 0, "total_posted": 0};
 }
 let body_str = json::stringify(body);
 let seed = sh::run("date +%s%N 2>/dev/null || date +%s");
 let delim = "XBATCH_" + seed + "_END";
 sh::run("cat > /tmp/x_batch_in.json << '" + delim + "'\n" + body_str + "\n" + delim);
 let raw = "";
 try {
  raw = sh::run(X_PYTHON + " " + X_SCRIPT + " batch /tmp/x_batch_in.json");
 } catch {
  return {"ok": false, "error": "x_post.py batch failed", "posted": [], "failed": [], "total_requested": 0, "total_posted": 0};
 }
 let out = sh_stdout(raw);
 if (out == null || len(out) == 0) {
  return {"ok": false, "error": "No output from x_post.py batch", "posted": [], "failed": [], "total_requested": 0, "total_posted": 0};
 }
 try {
  let parsed = json::parse(out);
  if (parsed["posted"] != null && parsed["total_posted"] != null) {
   log::audit("x:batch", "posted:" + to_string(parsed["total_posted"]) + " requested:" + to_string(parsed["total_requested"]));
   return parsed;
  }
  return {"ok": false, "error": parsed["error"], "posted": [], "failed": [], "total_requested": 0, "total_posted": 0};
 } catch {
  return {"ok": false, "error": "Invalid JSON from x_post batch: " + out, "posted": [], "failed": [], "total_requested": 0, "total_posted": 0};
 }
}

// Reply to a tweet. Trims to 280 in DAL. Returns {ok, tweet_id} or {ok: false, error}.
fn reply_x(tweet_id, text) {
 let key = "";
 try {
  key = config::get_env("X_API_KEY");
 } catch {
  return {"ok": false, "error": "X_API_KEY not set"};
 }
 if (key == null || len(key) == 0) {
  return {"ok": false, "error": "X_API_KEY not set"};
 }
 if (tweet_id == null || len(tweet_id) == 0) {
  return {"ok": false, "error": "tweet_id required"};
 }
 if (text == null || len(text) == 0) {
  return {"ok": false, "error": "Empty reply text"};
 }
 write_temp_text(text);
 let raw = "";
 try {
  raw = sh::run(X_PYTHON + " " + X_SCRIPT + " reply " + tweet_id + " - < /tmp/x_dal_tweet.txt");
 } catch {
  return {"ok": false, "error": "x_post.py reply failed"};
 }
 let out = sh_stdout(raw);
 if (out == null || len(out) == 0) {
  return {"ok": false, "error": "No output from x_post.py"};
 }
 try {
  let parsed = json::parse(out);
  if (parsed["ok"] == true) {
   log::audit("x:reply", "to:" + tweet_id + " tweet_id:" + to_string(parsed["tweet_id"]));
   return {"ok": true, "channel": "x", "tweet_id": parsed["tweet_id"], "result": out};
  }
  return {"ok": false, "error": parsed["error"]};
 } catch {
  return {"ok": false, "error": "Invalid JSON from x_post: " + out};
 }
}
