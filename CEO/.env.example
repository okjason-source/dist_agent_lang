# DAL agent AI (copy to .env and set one; do not commit .env)
# Run from agent_assistant: ./start.sh (loads .env automatically). From elsewhere: source .env then dal serve.

# OpenAI (for ai::generate_text). Either name works; start.sh syncs them.
# OPENAI_API_KEY=sk-...
# DAL_OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# DAL_OPENAI_MODEL=gpt-4o-mini

# Anthropic (if not using OpenAI)
# ANTHROPIC_API_KEY=sk-ant-...

# Communications skill — outbound messaging
# Telegram (for POST /api/send with channel=telegram)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Discord (for POST /api/send with channel=discord)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# X (Twitter) — for x.dal social media manager
# Create app at developer.x.com, enable Read and Write, generate keys
# (Use separate comment lines; do not put # inside a value — parsers treat it as comment.)
# X_API_KEY=...
# X_API_SECRET=...
# X_ACCESS_TOKEN=...
# X_ACCESS_TOKEN_SECRET=...

# Agent tool loop: max steps before "Max tool steps reached" (default 40, max 80)
# DAL_AGENT_MAX_TOOL_STEPS=40

# Runtime posture profiles (selected by ./start.sh --profile safe|fallback|ramp)
# DAL_CEO_PROFILE=auto
# - safe: reply_only + strict guards + native tool calls on
# - fallback: reply_only + strict guards + native tool calls off + legacy text JSON on
# - ramp: auto policy + non-strict guards + native tool calls on
#
# You can still override any value directly below.
# DAL_AGENT_POLICY_DEFAULT=auto
# DAL_AGENT_NATIVE_TOOL_CALLS_ENABLED=1
# DAL_AGENT_ENABLE_LEGACY_TEXT_JSON=0
# DAL_AGENT_GUARDS_STRICT_MODE=0
#
# Optional hard caps (recommended when testing new behavior on a real agent):
# DAL_AGENT_MAX_WALL_CLOCK_MS=30000
# DAL_AGENT_MAX_TOOL_CALLS_PER_TYPE=6
# DAL_AGENT_MAX_REPEATED_IDENTICAL_INVOCATIONS=2
# DAL_AGENT_MAX_CONSECUTIVE_NO_PROGRESS=2
# DAL_AGENT_MAX_TOTAL_TOKENS=20000
# DAL_AGENT_MAX_COST_MICROUSD=500000

# Web search: agent prefers Google when these are set (run scripts/google_search.py). Otherwise uses built-in search.
# Get key: Google Cloud Console → APIs & Services → enable Custom Search API → create key.
# Get cx: Programmable Search Engine (cse.google.com) → create search engine → Search engine ID.
# GOOGLE_SEARCH_API_KEY=...
# GOOGLE_SEARCH_CX=...
