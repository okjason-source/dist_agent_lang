# Scripting skill — write and run DAL or shell scripts.
#
# Behavior: Prefer scripts/ in the project for anything that should persist; use /tmp only for one-offs.
# When write_file is available, use it to create scripts then run (dal run or bash). When not, use run
# with heredoc and a unique delimiter. Always report success/failure and relevant output to the user.

skill "scripting" {
  category "development"
  description "Write and run DAL or shell scripts. Behavior: (1) Prefer project scripts/ for persistent scripts; /tmp for one-offs. (2) When write_file is available: create the file (e.g. scripts/foo.dal or scripts/bar.sh), then run with dal run scripts/foo.dal or bash scripts/bar.sh. (3) When write_file is not available: use run with heredoc (cat > path << 'UNIQUE_END' ... UNIQUE_END); pick a delimiter that does not appear in the script. (4) Use read_file and list_dir to inspect before/after. (5) Always report to the user: what ran, exit status or output, and any errors. For shell scripts, chmod +x when needed."
  tools "run" "search"
}
