# Multi-agent skill — coordinate specialized sub-agents for complex tasks.
#
# Agents: researcher (search/gather), coder (code/scripts), reviewer (quality/summary).
# Workflows chain agents together: research_and_summarize, code_and_review, deep_research.
# Use /api/workflow to run workflows, /api/agents to list active agents.

skill "multi_agent" {
  category "development"
  description "Coordinate specialized sub-agents (researcher, coder, reviewer) for complex tasks. Run multi-step workflows: research_and_summarize, code_and_review, deep_research. Each agent has a focused role and passes results to the next."
  tools "run" "search"
}
