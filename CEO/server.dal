@route("GET", "/api/ai-status")
fn api_ai_status(request) {
 touch_http_request(request);
 try {
  let reply = ai::generate_text(".");
  let ok = (reply != null && len(reply) > 0);
  if (!ok) {
   return {
    "status": 200,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"connected\":false,\"message\":\"LLM disconnected\"}"
   };
  }
  let is_placeholder = (reply == "Generated response to: .");
  if (is_placeholder) {
   return {
    "status": 200,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"connected\":false,\"message\":\"LLM disconnected (placeholder)\"}"
   };
  }
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"connected\":true,\"message\":\"LLM connected\"}"
  };
 } catch {
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"connected\":false,\"message\":\"LLM disconnected (error)\"}"
  };
 }
}

