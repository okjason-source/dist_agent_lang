// ---------------------------------------------------------------------------
// POST /api/agents/run — Run a task with a specific agent role
// Body: { "role": "researcher|coder|reviewer", "task": "..." }
// ---------------------------------------------------------------------------

@route("POST", "/api/agents/run")
fn api_agents_run(request) {
 try {
  let body_str = request.body;
  if (body_str == null || len(body_str) == 0) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"Missing body\"}"
   };
  }
  let body = json::parse(body_str);
  let role = body["role"];
  let task = body["task"];
  if (role == null || task == null) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"role and task are required\"}"
   };
  }

  log::info("agents", "API run: " + role + " task: " + task);
  let result = agents::run_with_agent(role, task);

  // Log to history
  history_append("agent:" + role, task, result["result"], "agent_task");

  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": json::stringify(result)
  };
 } catch {
  metrics_errors = metrics_errors + 1;
  return {
   "status": 500,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"error\":\"Agent run failed\"}"
  };
 }
}

