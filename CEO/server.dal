// ---------------------------------------------------------------------------
// POST /api/workflow — Execute a workflow
// Body: { "workflow": "research_and_summarize", "input": "topic or task" }
// ---------------------------------------------------------------------------

@route("POST", "/api/workflow")
fn api_workflow(request) {
 try {
  let body_str = request.body;
  if (body_str == null || len(body_str) == 0) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"Missing body\"}"
   };
  }
  let body = json::parse(body_str);
  let workflow_name = body["workflow"];
  let input = body["input"];
  if (workflow_name == null || input == null) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"workflow and input are required\"}"
   };
  }

  log::info("workflow", "API run: " + workflow_name + " input: " + input);
  log::audit("workflow", workflow_name + ": " + input);
  let result = workflows::run(workflow_name, input);

  // Log to history
  history_append("workflow:" + workflow_name, input, result["final_result"], "workflow");

  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": json::stringify(result)
  };
 } catch {
  metrics_errors = metrics_errors + 1;
  return {
   "status": 500,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"error\":\"Workflow execution failed\"}"
  };
 }
}

// ---------------------------------------------------------------------------
// POST /api/workflow/define — Save a custom workflow
// Body: {
//   "name": "my_workflow",
//   "description": "What this workflow does",
//   "steps": [
//     {"role": "researcher", "prompt": "Research {input}"},
//     {"role": "coder", "prompt": "Write code based on: {prev}"},
//     {"role": "reviewer", "prompt": "Review: {prev}"}
//   ]
// }
// Placeholders: {input} = original user input, {prev} = previous step output
// ---------------------------------------------------------------------------

@route("POST", "/api/workflow/define")
fn api_workflow_define(request) {
 try {
  let body_str = request.body;
  if (body_str == null || len(body_str) == 0) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"Missing body\"}"
   };
  }
  let body = json::parse(body_str);
  let name = body["name"];
  let steps = body["steps"];
  if (name == null || steps == null) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"name and steps are required\"}"
   };
  }
  // Reject overwriting built-ins
  if (name == "research_and_summarize" || name == "code_and_review" || name == "deep_research") {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"Cannot override built-in workflow\"}"
   };
  }

  let description = body["description"];
  if (description == null) {
   description = "Custom workflow";
  }

  let definition = {"steps": steps, "description": description};
  let saved = workflows::save_custom(name, definition);
  if (saved) {
   log::audit("workflow", "Defined custom: " + name);
   let out = {"ok": true, "name": name, "description": description, "message": "Workflow saved"};
   return {
    "status": 200,
    "headers": {"Content-Type": "application/json"},
    "body": json::stringify(out)
   };
  }
  return {
   "status": 500,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"error\":\"Failed to save workflow\"}"
  };
 } catch {
  return {
   "status": 500,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"error\":\"Define failed\"}"
  };
 }
}

// ---------------------------------------------------------------------------
// POST /api/workflow/delete — Delete a custom workflow
// Body: { "name": "my_workflow" }
// ---------------------------------------------------------------------------

@route("POST", "/api/workflow/delete")
fn api_workflow_delete(request) {
 try {
  let body_str = request.body;
  if (body_str == null || len(body_str) == 0) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"Missing body\"}"
   };
  }
  let body = json::parse(body_str);
  let name = body["name"];
  if (name == null) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"name is required\"}"
   };
  }
  let deleted = workflows::delete_custom(name);
  log::audit("workflow", "Deleted custom: " + name + " ok=" + to_string(deleted));
  let out = {"ok": true, "name": name, "message": "Workflow deleted"};
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": json::stringify(out)
  };
 } catch {
  return {
   "status": 500,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"error\":\"Delete failed\"}"
  };
 }
}

// ---------------------------------------------------------------------------
// GET  /api/x/status — Check if X (Twitter) is configured (.env loaded, all 4 vars set)
// POST /api/x/post  — Post a tweet. Body: { "text": "tweet text" }
// POST /api/x/reply — Reply to a tweet. Body: { "tweet_id": "123", "text": "reply" }
// ---------------------------------------------------------------------------

@route("GET", "/api/x/status")
fn api_x_status(request) {
 touch_http_request(request);
 let key = "";
 let secret = "";
 let token = "";
 let token_secret = "";
 try { key = config::get_env("X_API_KEY"); } catch { key = ""; }
 try { secret = config::get_env("X_API_SECRET"); } catch { secret = ""; }
 try { token = config::get_env("X_ACCESS_TOKEN"); } catch { token = ""; }
 try { token_secret = config::get_env("X_ACCESS_TOKEN_SECRET"); } catch { token_secret = ""; }
 let ok = (key != null && len(key) > 0 && secret != null && len(secret) > 0 && token != null && len(token) > 0 && token_secret != null && len(token_secret) > 0);
 if (ok) {
  return {"status": 200, "headers": {"Content-Type": "application/json"}, "body": json::stringify({"configured": true, "message": "X configured (all 4 env vars set). Post with POST /api/x/post or channel=x in /api/send."})};
 }
 return {"status": 200, "headers": {"Content-Type": "application/json"}, "body": json::stringify({"configured": false, "message": "X not configured. Add X_API_KEY, X_API_SECRET, X_ACCESS_TOKEN, X_ACCESS_TOKEN_SECRET to .env and start the server with ./start.sh so .env is loaded."})};
}

@route("POST", "/api/x/post")
fn api_x_post(request) {
 try {
  let body_str = request.body;
  if (body_str == null || len(body_str) == 0) {
   return { "status": 400, "headers": {"Content-Type": "application/json"}, "body": "{\"error\":\"Missing body\"}" };
  }
  let body = json::parse(body_str);
  let text = body["text"];
  if (text == null) { text = ""; }
  metrics_sends = metrics_sends + 1;
  let result = x::send_x(text);
  return { "status": 200, "headers": {"Content-Type": "application/json"}, "body": json::stringify(result) };
 } catch {
  metrics_errors = metrics_errors + 1;
  return { "status": 500, "headers": {"Content-Type": "application/json"}, "body": "{\"error\":\"X post failed\"}" };
 }
}

@route("POST", "/api/x/reply")
fn api_x_reply(request) {
 try {
  let body_str = request.body;
  if (body_str == null || len(body_str) == 0) {
   return { "status": 400, "headers": {"Content-Type": "application/json"}, "body": "{\"error\":\"Missing body\"}" };
  }
  let body = json::parse(body_str);
  let tweet_id = body["tweet_id"];
  let text = body["text"];
  if (tweet_id == null) { tweet_id = ""; }
  if (text == null) { text = ""; }
  metrics_sends = metrics_sends + 1;
  let result = x::reply_x(tweet_id, text);
  return { "status": 200, "headers": {"Content-Type": "application/json"}, "body": json::stringify(result) };
 } catch {
  metrics_errors = metrics_errors + 1;
  return { "status": 500, "headers": {"Content-Type": "application/json"}, "body": "{\"error\":\"X reply failed\"}" };
 }
}

// POST /api/x/batch — Post multiple tweets with limits (max 10 per batch, optional delay between posts).
// Body: { "tweets": ["tweet 1", "tweet 2", ...], "max_per_batch": 5?, "delay_seconds": 2? }
@route("POST", "/api/x/batch")
fn api_x_batch(request) {
 try {
  let body_str = request.body;
  if (body_str == null || len(body_str) == 0) {
   return { "status": 400, "headers": {"Content-Type": "application/json"}, "body": "{\"error\":\"Missing body\"}" };
  }
  let body = json::parse(body_str);
  if (body["tweets"] == null) {
   return { "status": 400, "headers": {"Content-Type": "application/json"}, "body": "{\"error\":\"tweets array required\"}" };
  }
  metrics_sends = metrics_sends + 1;
  let result = x::send_x_batch(body);
  return { "status": 200, "headers": {"Content-Type": "application/json"}, "body": json::stringify(result) };
 } catch {
  metrics_errors = metrics_errors + 1;
  return { "status": 500, "headers": {"Content-Type": "application/json"}, "body": "{\"error\":\"X batch failed\"}" };
 }
}

// ---------------------------------------------------------------------------
// POST /api/send — Send outbound message to a channel
// Body: { "channel": "telegram|discord|imessage|x", "recipient": "chat_id or tweet_id", "message": "text" }
// ---------------------------------------------------------------------------

@route("POST", "/api/send")
fn api_send(request) {
 try {
  let body_str = request.body;
  if (body_str == null || len(body_str) == 0) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"Missing body\"}"
   };
  }
  let body = json::parse(body_str);
  let channel = body["channel"];
  let recipient = body["recipient"];
  let message = body["message"];
  if (channel == null || message == null) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"channel and message are required\"}"
   };
  }
  if (recipient == null) {
   recipient = "";
  }
  metrics_sends = metrics_sends + 1;
  log::audit("send", "channel:" + channel + " recipient:" + recipient + " len:" + to_string(len(message)));
  let result = comms::send(channel, recipient, message);
  log_action("send", channel + ":" + recipient, "sent");
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": json::stringify(result)
  };
 } catch {
  metrics_errors = metrics_errors + 1;
  log::info("send", "error: send failed");
  return {
   "status": 500,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"error\":\"Send failed\"}"
  };
 }
}

// ---------------------------------------------------------------------------
// POST /api/reply — Reply through the originating channel
// Body: { "sender_id": "telegram_123", "message": "text" }
// ---------------------------------------------------------------------------

@route("POST", "/api/reply")
fn api_reply(request) {
 try {
  let body_str = request.body;
  if (body_str == null || len(body_str) == 0) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"Missing body\"}"
   };
  }
  let body = json::parse(body_str);
  let sender_id = body["sender_id"];
  let message = body["message"];
  if (sender_id == null || message == null) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"sender_id and message are required\"}"
   };
  }
  log::audit("reply", "to:" + sender_id + " len:" + to_string(len(message)));
  let result = comms::reply_to_sender(sender_id, message);
  log_action("reply", sender_id, "replied");
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": json::stringify(result)
  };
 } catch {
  metrics_errors = metrics_errors + 1;
  log::info("reply", "error: reply failed");
  return {
   "status": 500,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"error\":\"Reply failed\"}"
  };
 }
 }
}

