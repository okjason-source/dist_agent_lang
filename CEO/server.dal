// ---------------------------------------------------------------------------
// POST /api/message — Chat with evolve memory
// ---------------------------------------------------------------------------

@route("POST", "/api/message")
fn api_message(request) {
 try {
  let body_str = request.body;
  if (body_str == null) {
   body_str = "";
  }
  if (len(body_str) == 0) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"Missing body\"}"
   };
  }
  let body = json::parse(body_str);
  let content = body["content"];
  let sender_id = body["sender_id"];
  let policy = body["policy"];
  if (content == null) {
   content = body["text"];
  }
  if (content == null) {
   content = "";
  }
  if (sender_id == null) {
   sender_id = "web";
  }
  // If the client omits policy, do not pass "policy" into ai::agent_run so
  // DAL_AGENT_POLICY_DEFAULT (runtime env) applies. Defaulting to "auto" here
  // prevented rollback drills (reply_only default) from working.

  metrics_messages = metrics_messages + 1;
  log::info("message", "from:" + sender_id + " len:" + to_string(len(content)));

  // Build context-enriched prompt so the LLM sees recent memory
  let enriched = enrich_prompt(content);

  let reply = "";
  let tool_steps_count = 0;
  let max_steps_reached = false;
  let route = "";
  let last_tool_names = [];
  let effective_policy = "";
  let termination_reason = "";
  let guard_stopped = false;
  let observability = null;
  try {
   let ai_result = null;
   if (policy == null || len(policy) == 0) {
    ai_result = ai::agent_run({"message": enriched});
   } else {
    ai_result = ai::agent_run({"message": enriched, "policy": policy});
   }
   if (ai_result != null) {
    reply = ai_result["final_text"];
    tool_steps_count = ai_result["steps_used"];
    max_steps_reached = ai_result["max_steps_reached"];
    route = ai_result["route"];
    last_tool_names = ai_result["tool_trace"];
    effective_policy = ai_result["policy"];
    termination_reason = ai_result["termination_reason"];
    if (ai_result["guard_stopped"] != null) {
     guard_stopped = ai_result["guard_stopped"];
    }
    observability = ai_result["observability"];
   }
  } catch {
   reply = "AI is not configured. See README for setup.";
  }
  if (reply == null || len(reply) == 0) {
   reply = "No response. See README for setup.";
  }

  // Persist this exchange to evolve memory and history
  log_conversation(content, reply);
  history_append(sender_id, content, reply, "message");
  log_action("message", "from:" + sender_id, "replied");
  log::info("message", "replied to:" + sender_id + " len:" + to_string(len(reply)));
  trim_context();
  history_trim();

  let out = {
   "reply": reply,
   "sender_id": sender_id,
   "tool_steps_count": tool_steps_count,
   "max_steps_reached": max_steps_reached,
   "route": route,
   "policy": effective_policy,
   "termination_reason": termination_reason,
   "guard_stopped": guard_stopped,
   "tool_trace": last_tool_names,
   "last_tool_names": last_tool_names,
   "observability": observability
  };
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": json::stringify(out)
  };
 } catch {
  metrics_errors = metrics_errors + 1;
  log::info("message", "error: server error");
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"reply\":\"Server error. Send JSON with content or text.\",\"sender_id\":\"web\"}"
  };
 }
}

// ---------------------------------------------------------------------------
// POST /api/task — Task execution with evolve memory
// ---------------------------------------------------------------------------

@route("POST", "/api/task")
fn api_task(request) {
 try {
  let body_str = request.body;
  if (body_str == null || len(body_str) == 0) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"Missing body\"}"
   };
  }
  let body = json::parse(body_str);
  let description = body["description"];
  let policy = body["policy"];
  if (description == null) {
   description = body["task"];
  }
  if (description == null) {
   description = "";
  }
  // Same as /api/message: omit policy when unset so DAL_AGENT_POLICY_DEFAULT applies.

  metrics_tasks = metrics_tasks + 1;
  log::info("task", "started: " + description);

  let enriched = enrich_prompt(description);

  let result = "";
  let tool_steps_count = 0;
  let max_steps_reached = false;
  let route = "";
  let last_tool_names = [];
  let effective_policy = "";
  let termination_reason = "";
  let guard_stopped = false;
  let observability = null;
  try {
   let ai_result = null;
   if (policy == null || len(policy) == 0) {
    ai_result = ai::agent_run({"message": enriched});
   } else {
    ai_result = ai::agent_run({"message": enriched, "policy": policy});
   }
   if (ai_result != null) {
    result = ai_result["final_text"];
    tool_steps_count = ai_result["steps_used"];
    max_steps_reached = ai_result["max_steps_reached"];
    route = ai_result["route"];
    last_tool_names = ai_result["tool_trace"];
    effective_policy = ai_result["policy"];
    termination_reason = ai_result["termination_reason"];
    if (ai_result["guard_stopped"] != null) {
     guard_stopped = ai_result["guard_stopped"];
    }
    observability = ai_result["observability"];
   }
  } catch {
   result = "AI is not configured. See README for setup.";
  }
  if (result == null || len(result) == 0) {
   result = "No result.";
  }

  log_conversation(description, result);
  history_append("task", description, result, "task");
  log_action("task", description, "completed");
  log::info("task", "completed: " + description);
  trim_context();
  history_trim();

  let out = {
   "ok": true,
   "task": description,
   "result": result,
   "tool_steps_count": tool_steps_count,
   "max_steps_reached": max_steps_reached,
   "route": route,
   "policy": effective_policy,
   "termination_reason": termination_reason,
   "guard_stopped": guard_stopped,
   "tool_trace": last_tool_names,
   "last_tool_names": last_tool_names,
   "observability": observability
  };
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": json::stringify(out)
  };
 } catch {
  return {
   "status": 500,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"error\":\"Task execution failed\"}"
  };
 }
}

// ---------------------------------------------------------------------------
// POST /api/context/summary — Summarize and compress context
// ---------------------------------------------------------------------------

@route("POST", "/api/context/summary")
fn api_context_summary(request) {
 touch_http_request(request);
 try {
  let ctx = load_context();
  if (ctx == null || len(ctx) == 0) {
   return {
    "status": 200,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"ok\":true,\"message\":\"No context to summarize\"}"
   };
  }
  let summary = "";
  try {
   summary = ai::generate_text("Summarize the following agent context into a concise paragraph. Keep key facts, decisions, and user preferences. Drop routine greetings.\n\n" + ctx);
  } catch {
   summary = "Could not generate summary (AI not configured).";
  }
  evolve::append_summary(summary, "auto-summary");
  trim_context();
  let out = {"ok": true, "summary": summary};
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": json::stringify(out)
  };
 } catch {
  return {
   "status": 500,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"error\":\"Summary failed\"}"
  };
 }
}

// ---------------------------------------------------------------------------
// POST /api/preference — Append one learned preference (Phase 2)
// Body: {"preference": "User prefers bullet points."}
// ---------------------------------------------------------------------------

@route("POST", "/api/preference")
fn api_preference(request) {
 try {
  let body_str = request.body;
  if (body_str == null || len(body_str) == 0) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"Missing body\"}"
   };
  }
  let body = json::parse(body_str);
  let pref = body["preference"];
  if (pref == null) {
   pref = body["text"];
  }
  if (pref == null || len(to_string(pref)) == 0) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"Missing preference or text\"}"
   };
  let line = to_string(pref);
  sh::run("printf '%s\n' '" + line + "' >> learned_preferences.md 2>/dev/null || echo '" + line + "' >> learned_preferences.md");
  try {
   evolve::append_log("preference", line, "");
  } catch {
   // non-fatal
  }
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"ok\":true,\"message\":\"Preference appended\"}"
  };
 } catch {
  return {
   "status": 500,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"error\":\"Failed to append preference\"}"
  };
 }
}

// ---------------------------------------------------------------------------
// POST /api/feedback — Append one feedback entry for reinforcement (Phase 3)
// Body: {"rating": 1|0|-1 or \"up\"|\"down\", \"comment\": \"optional\"}
// ---------------------------------------------------------------------------

@route("POST", "/api/feedback")
fn api_feedback(request) {
 try {
  let body_str = request.body;
  if (body_str == null || len(body_str) == 0) {
   return {
    "status": 400,
    "headers": {"Content-Type": "application/json"},
    "body": "{\"error\":\"Missing body\"}"
   };
  }
  let body = json::parse(body_str);
  let rating = body["rating"];
  let comment = body["comment"];
  if (comment == null) {
   comment = "";
  }
  let ts = "";
  try {
   ts = sh_stdout(sh::run("date -u '+%Y-%m-%dT%H:%M:%SZ'"));
  } catch {
   ts = "unknown";
  }
  let entry = {"ts": ts, "rating": rating, "comment": to_string(comment)};
  let line = json::stringify(entry);
  sh::run("printf '%s\n' '" + line + "' >> " + FEEDBACK_FILE + " 2>/dev/null || echo '" + line + "' >> " + FEEDBACK_FILE);
  try {
   evolve::append_log("feedback", to_string(rating), to_string(comment));
  } catch {
   // non-fatal
  }
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"ok\":true,\"message\":\"Feedback recorded\"}"
  };
 } catch {
  return {
   "status": 500,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"error\":\"Failed to record feedback\"}"
  };
 }
}

// ---------------------------------------------------------------------------
// GET /api/history — Retrieve conversation history
// Query: ?limit=50 (default 50, max 500)
// ---------------------------------------------------------------------------

@route("GET", "/api/history")
fn api_history(request) {
 touch_http_request(request);
 let limit = 50;
 // DAL route handlers don't parse query params natively, use default
 let entries = history_read(limit);
 let count = history_count();
 let out_str = "{\"ok\":true,\"total\":" + to_string(count) + ",\"showing\":" + to_string(limit) + ",\"entries\":" + entries + "}";
 return {
  "status": 200,
  "headers": {"Content-Type": "application/json"},
  "body": out_str
 };
}

