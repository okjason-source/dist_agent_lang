 return {
  "status": 200,
  "headers": {"Content-Type": "application/json"},
  "body": "{\"status\":\"ok\",\"service\":\"dal-ceo\",\"version\":\"0.2.0\"}"
 };
}

@route("GET", "/api/status")
fn api_status(request) {
 touch_http_request(request);
 let server_metrics = get_metrics();

 let runtime = load_agent_runtime();
 let agent_count = 0;
 let serve_agent = "";
 let agent_info = null;
 if (runtime != null) {
  serve_agent = runtime["serve_agent_id"];
  if (serve_agent == null) {
   serve_agent = "";
  }
  let contexts = runtime["agent_contexts"];
  if (contexts != null) {
   // Count agents via the runtime file
   try {
    let count_str = sh::run("cat .dal/agent_runtime.json | python3 -c \"import sys,json; print(len(json.load(sys.stdin).get('agent_contexts',{})))\" 2>/dev/null");
    if (count_str != null && len(count_str) > 0) {
     agent_count = to_int(count_str);
    }
   } catch {
    agent_count = 0;
   }
   // Get serve agent details
   if (len(serve_agent) > 0 && contexts[serve_agent] != null) {
    let ctx = contexts[serve_agent];
    let cfg = ctx["config"];
    let perf = ctx["performance_metrics"];
    agent_info = {
     "agent_id": serve_agent,
     "name": cfg["name"],
     "type": cfg["agent_type"],
     "role": cfg["role"],
     "status": ctx["status"],
     "skills": cfg["skills"],
     "trust_score": ctx["trust_score"],
     "metrics": perf
    };
   }
  }
 }

 let ctx_len = 0;
 let ctx = load_context();
 if (ctx != null) {
  ctx_len = len(ctx);
 }

 let frontend_source = "fallback";
 let idx_body = read_from_public(get_ui_base(), "index.html");
 if (idx_body != null && len(idx_body) > 0) {
  frontend_source = "public";
 }

 let out = {
  "ok": true,
  "version": "0.2.0",
  "server": server_metrics,
  "agent_count": agent_count,
  "serve_agent": agent_info,
  "context_length": ctx_len,
  "frontend_source": frontend_source
 };
 return {
  "status": 200,
  "headers": {"Content-Type": "application/json"},
  "body": json::stringify(out)
 };
}

