 };
}

@route("GET", "/api/diag")
fn api_diag(request) {
 touch_http_request(request);
 try {
  let reply = ai::generate_text(".");
  let is_placeholder = (reply == "Generated response to: .");
  let rlen = 0;
  if (reply != null) {
   rlen = len(reply);
  }
  let out = {"status": "ok", "is_placeholder": is_placeholder, "reply_len": rlen};
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": json::stringify(out)
  };
 } catch {
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": "{\"status\":\"error\",\"message\":\"ai::generate_text threw\"}"
  };
 }
}

