  };
 }
}

// ---------------------------------------------------------------------------
// Scheduling and task monitor (agent-only; see docs/SCHEDULING_AND_TASK_MONITOR.md)
// POST /api/schedule — Add a scheduled task. Body: { "description": "...", "run_at": "2025-03-07T10:00:00Z" (optional) }
// GET  /api/tasks   — List scheduled tasks and completed ids (task monitor)
// POST /api/tasks/complete — Mark a task completed. Body: { "id": "sched_0" }
// ---------------------------------------------------------------------------

@route("POST", "/api/schedule")
fn api_schedule(request) {
 try {
  let body_str = request.body;
  if (body_str == null || len(body_str) == 0) {
   return { "status": 400, "headers": {"Content-Type": "application/json"}, "body": "{\"error\":\"Missing body\"}" };
  }
  let body = json::parse(body_str);
  let description = body["description"];
  if (description == null) { description = ""; }
  let run_at = body["run_at"];
  if (run_at == null) { run_at = ""; }
  schedule_id_counter = schedule_id_counter + 1;
  let id = "sched_" + to_string(schedule_id_counter);
  let new_task = { "id": id, "description": description, "run_at": run_at, "status": "pending" };
  scheduled_tasks = scheduled_tasks + [new_task];
  log::info("schedule", "added: " + id);
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": json::stringify({"ok": true, "id": id})
  };
 } catch {
  return { "status": 500, "headers": {"Content-Type": "application/json"}, "body": "{\"error\":\"Schedule failed\"}" };
 }
}

@route("GET", "/api/tasks")
fn api_tasks(request) {
 touch_http_request(request);
 let out = {"ok": true, "tasks": scheduled_tasks, "completed_ids": completed_task_ids};
 return {
  "status": 200,
  "headers": {"Content-Type": "application/json"},
  "body": json::stringify(out)
 };
}

@route("POST", "/api/tasks/complete")
fn api_tasks_complete(request) {
 try {
  let body_str = request.body;
  if (body_str == null || len(body_str) == 0) {
   return { "status": 400, "headers": {"Content-Type": "application/json"}, "body": "{\"error\":\"Missing body\"}" };
  }
  let body = json::parse(body_str);
  let id = body["id"];
  if (id == null) { id = ""; }
  if (len(id) == 0) {
   return { "status": 400, "headers": {"Content-Type": "application/json"}, "body": "{\"error\":\"id required\"}" };
  }
  completed_task_ids = completed_task_ids + [id];
  log::info("tasks", "completed: " + id);
  return {
   "status": 200,
   "headers": {"Content-Type": "application/json"},
   "body": json::stringify({"ok": true})
  };
 } catch {
  return { "status": 500, "headers": {"Content-Type": "application/json"}, "body": "{\"error\":\"Complete failed\"}" };
 }
}

