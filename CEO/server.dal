// DAL CEO — HTTP server with memory (evolve) and tool-using AI.
// Run: dal serve server.dal --port 4040
//
// Routes:
//   GET  /              — Chat UI
//   POST /api/message   — Send message, get AI reply (with context)
//   POST /api/task      — Task execution
//   POST /api/send      — Send outbound message to a channel
//   GET  /api/context   — View current agent memory
//   GET  /api/ai-status — LLM connection check
//   POST /api/x/batch   — Post multiple tweets (max 10/batch, optional delay)
//   POST /api/schedule  — Add scheduled task. GET /api/tasks — task monitor. POST /api/tasks/complete — mark done
//   GET  /api/processing — What's running (tasks, metrics; see docs/TROUBLESHOOTING.md)
//   GET  /health        — Liveness

import "./communications.dal" as comms;
import "./x.dal" as x;
import "./agents.dal" as agents;
import "./workflows.dal" as workflows;

// ---------------------------------------------------------------------------
// Route contract (overhaul: single place so we don't drift)
// ---------------------------------------------------------------------------
// Handlers return a map: { "status": 200|4xx|5xx, "headers": { "Content-Type": "..." }, "body": string }.
// Success: status 200, body is JSON string (e.g. json::stringify({ "ok": true, ... })).
// Error: status 400/500, body is JSON string with standard shape { "ok": false, "error": "message" }
// (or { "error": "message" } for backward compatibility). All route bodies are strings (UTF-8).

// ---------------------------------------------------------------------------
// Startup — validate config
// ---------------------------------------------------------------------------

fn check_config() {
 let ai_cfg = config::get_ai_config();
 let model = ai_cfg["model"];
 log::info("dal-ceo", "Starting v0.2.0");
 log::info("config", "AI model: " + to_string(model));

 try {
  let key = config::get_env("OPENAI_API_KEY");
  log::info("config", "OPENAI_API_KEY is set (len " + to_string(len(key)) + ")");
 } catch {
  try {
   let key = config::get_env("DAL_OPENAI_API_KEY");
   log::info("config", "DAL_OPENAI_API_KEY is set (len " + to_string(len(key)) + ")");
  } catch {
   try {
    let key = config::get_env("ANTHROPIC_API_KEY");
    log::info("config", "ANTHROPIC_API_KEY is set (len " + to_string(len(key)) + ")");
   } catch {
    log::info("config", "WARNING: No AI API key found — set OPENAI_API_KEY or DAL_OPENAI_API_KEY in .env");
   }
  }
 }
}

check_config();

// Satisfies unused-parameter checks: route handlers must bind `request`, but many
// do not read body/query; touching path marks `request` as used.
fn touch_http_request(request) {
 return len(request.path);
}

// ---------------------------------------------------------------------------
// Server metrics (in-memory counters, reset on restart)
// ---------------------------------------------------------------------------

let metrics_messages = 0;
let metrics_tasks = 0;
let metrics_sends = 0;
let metrics_errors = 0;

// Scheduling and task monitor (agent-only; see docs/SCHEDULING_AND_TASK_MONITOR.md)
let scheduled_tasks = [];
let completed_task_ids = [];
let schedule_id_counter = 0;

fn get_metrics() {
 return {
  "messages_handled": metrics_messages,
  "tasks_completed": metrics_tasks,
  "outbound_sends": metrics_sends,
  "errors": metrics_errors
 };
}

fn load_agent_runtime() {
 try {
  let raw = sh::run("cat .dal/agent_runtime.json 2>/dev/null");
  if (raw != null && len(raw) > 0) {
   return json::parse(raw);
  }
 } catch {
  // file may not exist yet
 }
 return null;
}

// ---------------------------------------------------------------------------
// Context / memory helpers
// ---------------------------------------------------------------------------

let CONTEXT_MAX_LINES = 200;

fn load_context() {
 try {
  let ctx = evolve::load();
  if (ctx == null) {
   return "";
  }
  return ctx;
 } catch {
  return "";
 }
}

// Use skills::list() when available (DAL built-in); fallback to shell grep/sed.
fn skill_line(item) {
 if (item == null || item["name"] == null) { return ""; }
 let desc = item["description"];
 if (desc == null) { desc = ""; }
 return "Skill: " + to_string(item["name"]) + "\n  " + to_string(desc) + "\n";
}

fn load_skills_context() {
 try {
  let list = skills::list();
  if (list != null && type(list) == "array" && len(list) > 0) {
   let lines = skill_line(list[0]) + skill_line(list[1]) + skill_line(list[2]) + skill_line(list[3]) + skill_line(list[4]) + skill_line(list[5]) + skill_line(list[6]) + skill_line(list[7]) + skill_line(list[8]) + skill_line(list[9]);
   if (len(lines) > 0) {
    return lines;
   }
  }
 } catch {
  // fallback
 }
 try {
  let raw = sh::run("cat skills/*.skill.dal 2>/dev/null");
  if (raw == null || len(raw) == 0) {
   return "";
  }
  let descriptions = sh::run("grep -E '^\\s*(skill|description)' skills/*.skill.dal 2>/dev/null | sed 's/^.*skill /Skill: /; s/^.*description /  /; s/[\"{}]//g'");
  if (descriptions == null || len(descriptions) == 0) {
   return "";
  }
  return descriptions;
 } catch {
  return "";
 }
}

// ---------------------------------------------------------------------------
// Personality, learned preferences, reinforcement (PERSONALITY_AND_LEARNING_PLAN)
// ---------------------------------------------------------------------------

fn sh_stdout(res) {
 if (res == null) { return ""; }
 if (type(res) == "map" && res["stdout"] != null) {
  return res["stdout"];
 }
 return to_string(res);
}

fn load_personality() {
 try {
  let res = sh::run("cat personality.md 2>/dev/null");
  let text = sh_stdout(res);
  if (text != null && len(text) > 0) {
   return text;
  }
 } catch {
  // file missing or unreadable
 }
 return "";
}

fn load_learned_preferences() {
 try {
  let res = sh::run("cat learned_preferences.md 2>/dev/null");
  let text = sh_stdout(res);
  if (text != null && len(text) > 0) {
   return text;
  }
 } catch {
  // file missing or unreadable
 }
 return "";
}

let FEEDBACK_FILE = "feedback.jsonl";
let FEEDBACK_LAST_N = 10;

fn load_reinforcement_summary() {
 try {
  let res = sh::run("test -s " + FEEDBACK_FILE + " && wc -l < " + FEEDBACK_FILE + " 2>/dev/null || echo 0");
  let text = sh_stdout(res);
  if (text == null || len(text) == 0) {
   return "";
  }
  let n = 0;
  try {
   n = to_int(text);
  } catch {
   return "";
  }
  if (n <= 0) {
   return "";
  }
  return "You have " + to_string(n) + " recent feedback entries (UI cap " + to_string(FEEDBACK_LAST_N) + "). Favor what the user rated positively and avoid what they rated negatively.";
 } catch {
  return "";
 }
}

// Explore & exploit: encourage using run/search to discover, and to reuse what worked (from memory).
// Web search behavior: prefer Google via run script when available; fall back to the built-in search action.
fn load_explore_exploit_block(has_memory) {
 let base = "When you don't have a specific tool for a task, use **run** or **search** to find documentation, APIs, or commands. Explore your environment (e.g. run \"ls\" or \"ls -la\", run \"cat <file>\") when you need to see files or output. Use your past executions in context as examples; if something worked before, exploit that pattern again.";
 let search_behavior = " For web search use Google when possible: run `python3 scripts/google_search.py 'your query'` (from the project root). If that fails or says not configured, use the **search** action as fallback.";
 if (has_memory) {
  return base + search_behavior + " Your recent memory above may show past tool use (run, search); apply similar approaches when they worked.";
 }
 return base + search_behavior;
}

fn enrich_prompt(user_message) {
 let ctx = load_context();
 let skills = load_skills_context();
 let personality = load_personality();
 let preferences = load_learned_preferences();
 let reinforcement = load_reinforcement_summary();
 let prompt = user_message;

 let has_ctx = (ctx != null && len(ctx) > 0);
 let has_skills = (skills != null && len(skills) > 0);
 let explore_exploit = load_explore_exploit_block(has_ctx);

 let prefix = "";
 if (personality != null && len(personality) > 0) {
  prefix = "## Your personality\n\n" + personality + "\n\n---\n\n";
 }
 if (preferences != null && len(preferences) > 0) {
  prefix = prefix + "## Learned preferences (follow these)\n\n" + preferences + "\n\n---\n\n";
 }
 if (reinforcement != null && len(reinforcement) > 0) {
  prefix = prefix + "## Reinforcement (recent feedback)\n\n" + reinforcement + "\n\n---\n\n";
 }
 prefix = prefix + "## Explore and exploit (skills and environment)\n\n" + explore_exploit + "\n\n---\n\n";
 if (has_skills) {
  prefix = prefix + "## Your skills and capabilities\n\n" + skills + "\n\nYou can send outbound messages via /api/send (channel: telegram, discord, imessage, x) or the X endpoints above. When a user's sender_id starts with telegram_, discord_, imessage_, or x_, reply through that channel. When calling this server with curl, use the full URL http://localhost:4040.\n\n---\n\n";
 }
 if (has_ctx) {
  prefix = prefix + "## Recent memory (context from previous interactions)\n\n" + ctx + "\n\n---\n\n";
 }

 return prefix + "## Current message\n\n" + prompt;
}

fn log_conversation(user_msg, agent_reply) {
 try {
  evolve::append_conversation(user_msg, agent_reply);
 } catch {
  // evolve write failed — non-fatal
 }
}

fn log_action(action, detail, result) {
 try {
  evolve::append_log(action, detail, result);
 } catch {
  // non-fatal
 }
}

fn trim_context() {
 try {
  evolve::trim_retention(CONTEXT_MAX_LINES);
 } catch {
  // non-fatal
 }
}

// ---------------------------------------------------------------------------
// Conversation history (JSONL file — one JSON object per line)
// ---------------------------------------------------------------------------

let HISTORY_FILE = "history.jsonl";
let HISTORY_MAX_ENTRIES = 500;

fn history_append(sender_id, content, reply, entry_type) {
 try {
  let ts = sh::run("date -u '+%Y-%m-%dT%H:%M:%SZ'");
  if (ts != null) {
   // Trim trailing newline from date output
   ts = sh::run("echo -n '" + ts + "'");
  }
  let entry = {
   "ts": ts,
   "type": entry_type,
   "sender": sender_id,
   "content": content,
   "reply": reply
  };
  let line = json::stringify(entry);
  // Escape single quotes in the JSON line for the shell
  let safe_line = sh::run("printf '%s' '" + line + "'");
  sh::run("echo '" + safe_line + "' >> " + HISTORY_FILE);
 } catch {
  // non-fatal — history write failed
 }
}

fn history_read(max_entries) {
 try {
  let raw = sh::run("tail -n " + to_string(max_entries) + " " + HISTORY_FILE + " 2>/dev/null");
  if (raw == null || len(raw) == 0) {
   return "[]";
  }
  // Wrap JSONL lines into a JSON array
  let arr = sh::run("tail -n " + to_string(max_entries) + " " + HISTORY_FILE + " 2>/dev/null | python3 -c \"import sys; lines=[l.strip() for l in sys.stdin if l.strip()]; print('[' + ','.join(lines) + ']')\"");
  if (arr == null || len(arr) == 0) {
   return "[]";
  }
  return arr;
 } catch {
  return "[]";
 }
}

fn history_count() {
 try {
  let count_str = sh::run("wc -l < " + HISTORY_FILE + " 2>/dev/null");
  if (count_str != null && len(count_str) > 0) {
   return to_int(count_str);
  }
 } catch {
  // file doesn't exist yet
 }
 return 0;
}

fn history_trim() {
 try {
  let count = history_count();
  if (count > HISTORY_MAX_ENTRIES) {
   let keep = to_string(HISTORY_MAX_ENTRIES);
   sh::run("tail -n " + keep + " " + HISTORY_FILE + " > " + HISTORY_FILE + ".tmp && mv " + HISTORY_FILE + ".tmp " + HISTORY_FILE);
   log::info("history", "trimmed to " + keep + " entries");
  }
 } catch {
  // non-fatal
 }
}



fn get_ui_base() {
 let base = "";
 try {
  let root = config::get_env("DAL_SERVER_ROOT");
  if (root != null && len(root) > 0) { base = root; }
 } catch { }
 if (len(base) == 0) {
  try {
   let root = config::get_env("DAL_CEO_ROOT");
   if (root != null && len(root) > 0) { base = root; }
  } catch { }
 }
 if (len(base) == 0) {
  // Fallback for manual `dal serve server.dal` runs from project root.
  try {
   let cwd = sh::run("pwd 2>/dev/null");
   if (cwd != null && len(cwd) > 0) { base = cwd; }
  } catch { }
 }
 return base;
}

fn read_from_public(base, filename) {
 try {
  let path = "public/" + filename;
  if (len(base) > 0) { path = base + "/public/" + filename; }
  let out = sh::run("cat \"" + path + "\" 2>/dev/null");
  if (out != null && len(out) > 0) {
   return out;
  }
 } catch { }
 try {
  let script_dir = sh::run("dirname \"$0\" 2>/dev/null");
  if (script_dir != null && len(script_dir) > 0) {
   let alt = script_dir + "/public/" + filename;
   let out2 = sh::run("cat \"" + alt + "\" 2>/dev/null");
   if (out2 != null && len(out2) > 0) {
    return out2;
   }
  }
 } catch { }
 return null;
}

fn get_index_html(base) {
 let body = read_from_public(base, "index.html");
 if (body != null && len(body) > 0) {
  return body;
 }
 return default_index_html();
}

fn get_styles_css(base) {
 let body = read_from_public(base, "styles.css");
 if (body != null && len(body) > 0) {
  return body;
 }
 return default_styles_css();
}

fn get_app_js(base) {
 let body = read_from_public(base, "app.js");
 if (body != null && len(body) > 0) {
  return body;
 }
 return default_app_js();
}

fn default_index_html() {
 return "<!DOCTYPE html><html lang=\"en\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>DAL CEO</title><link rel=\"stylesheet\" href=\"/styles.css\"></head><body><div class=\"header\"><h1>DAL CEO</h1><p>Chat, run commands, or give tasks. Memory-enabled.</p><div class=\"ai-status\" id=\"ai-status\"><span class=\"ai-dot checking\" id=\"ai-dot\"></span><span id=\"ai-label\">Checking…</span></div><div class=\"ai-fix\" id=\"ai-fix\"></div></div><div class=\"layout\"><main class=\"chat-main\"><div id=\"messages\"></div><form class=\"input-bar\" id=\"form\"><input type=\"text\" id=\"input\" placeholder=\"Message your agent...\" autocomplete=\"off\"><button type=\"submit\">Send</button></form></main><aside class=\"panels\" id=\"bottom-panels\"><section class=\"panel-column\" id=\"panel-history\"><div class=\"panel-header\"><h2>History</h2><button type=\"button\" id=\"history-refresh\">↻</button><button type=\"button\" id=\"history-clear\">Clear</button></div><div id=\"history-list\" class=\"history-list\"></div></section><div class=\"panel-divider\" data-divider=\"history-task\"></div><section class=\"panel-column\" id=\"panel-task\"><div class=\"panel-header\"><h2>Task</h2></div><form id=\"task-form\" class=\"panel-form\"><textarea id=\"task-input\" placeholder=\"Describe the task...\" rows=\"3\"></textarea><button type=\"submit\">Run task</button></form><div id=\"task-result\" class=\"panel-result\"></div></section><div class=\"panel-divider\" data-divider=\"task-workflow\"></div><section class=\"panel-column\" id=\"panel-workflow\"><div class=\"panel-header\"><h2>Workflow</h2></div><form id=\"workflow-form\" class=\"panel-form\"><label for=\"workflow-select\">Workflow</label><select id=\"workflow-select\"><option value=\"\">Loading…</option></select><label for=\"workflow-input\">Input</label><input type=\"text\" id=\"workflow-input\" placeholder=\"e.g. topic\"><button type=\"submit\">Run workflow</button></form><div id=\"workflow-result\" class=\"panel-result\"></div></section></aside></div><script src=\"/app.js\"></script><script>(function(){var c=document.getElementById('bottom-panels'),l=document.getElementById('panel-history'),m=document.getElementById('panel-task'),r=document.getElementById('panel-workflow'),d1=document.querySelector('[data-divider=\"history-task\"]'),d2=document.querySelector('[data-divider=\"task-workflow\"]');if(!c||!l||!m||!r||!d1||!d2)return;function set(a,b,cc){l.style.flex='0 0 '+a+'px';m.style.flex='0 0 '+b+'px';r.style.flex='0 0 '+cc+'px';}function cur(){return{a:l.getBoundingClientRect().width,b:m.getBoundingClientRect().width,c:r.getBoundingClientRect().width};}function bind(div,side){div.addEventListener('pointerdown',function(ev){if(window.matchMedia('(max-width:768px)').matches)return;ev.preventDefault();var sx=ev.clientX,s=cur(),min=220;function mv(e){var dx=e.clientX-sx,a=s.a,b=s.b,cc=s.c;if(side==='left'){a=Math.max(min,s.a+dx);b=Math.max(min,s.b-dx);}else{b=Math.max(min,s.b+dx);cc=Math.max(min,s.c-dx);}set(a,b,cc);}function up(){window.removeEventListener('pointermove',mv);window.removeEventListener('pointerup',up);}window.addEventListener('pointermove',mv);window.addEventListener('pointerup',up);});}bind(d1,'left');bind(d2,'right');})();</script></body></html>";
}

fn default_styles_css() {
 return "*{box-sizing:border-box;margin:0;padding:0}body{font-family:system-ui,sans-serif;background:#0a0a0f;color:#e4e4e7;min-height:100vh;display:flex;flex-direction:column}.header{padding:1rem 1.25rem;border-bottom:1px solid #1e1e2e;background:#0f0f18}.header h1{font-size:1.1rem;font-weight:600}.header p{color:#52525b;font-size:.8rem;margin-top:.25rem}.ai-status{display:inline-flex;align-items:center;gap:.35rem;font-size:.7rem;color:#52525b;margin-top:.4rem}.ai-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}.ai-dot.connected{background:#00d4aa}.ai-dot.disconnected{background:#ef4444}.ai-dot.checking{background:#eab308;animation:pulse 1s ease-in-out infinite}@keyframes pulse{50%{opacity:.4}}.ai-fix{margin-top:.5rem;padding:.5rem .75rem;background:#141420;border:1px solid #1e1e2e;border-radius:6px;font-size:.7rem;color:#71717a}.layout{display:flex;flex-direction:column;flex:1;min-height:0}.chat-main{flex:1;display:flex;flex-direction:column;min-width:0}#messages{flex:1;overflow-y:auto;padding:1rem;display:flex;flex-direction:column;gap:.6rem}.msg{padding:.6rem .85rem;border-radius:10px;max-width:85%;line-height:1.5;font-size:.9rem}.msg.user{background:#1a1a2e;align-self:flex-start;border:1px solid #252540}.msg.agent{background:#0f1a1a;align-self:flex-end;border:1px solid #0d3d3d}.msg .who{font-size:.65rem;color:#52525b;margin-bottom:.2rem}.input-bar{display:flex;gap:.5rem;padding:1rem;border-top:1px solid #1e1e2e;background:#0f0f18}.input-bar input{flex:1;padding:.65rem .85rem;border-radius:8px;border:1px solid #252540;background:#141420;color:#e4e4e7;font-size:.9rem}.input-bar button{padding:.65rem 1.1rem;border-radius:8px;border:none;background:#00d4aa;color:#0a0a0f;font-weight:600;cursor:pointer}.panels{flex-shrink:0;width:100%;max-height:42vh;border-top:1px solid #1e1e2e;background:#0f0f18;display:flex;flex-direction:row;overflow:hidden}.panel-column{display:flex;flex:1 1 33%;min-width:220px;min-height:0;flex-direction:column;overflow:hidden;padding:.75rem}.panel-column+.panel-column{border-left:1px solid #1e1e2e}.panel-divider{width:8px;flex:0 0 8px;cursor:col-resize;background:linear-gradient(180deg,#0f0f18 0%,#141420 50%,#0f0f18 100%);border-left:1px solid #1e1e2e;border-right:1px solid #1e1e2e;position:relative}.panel-divider:after{content:'';position:absolute;top:35%;bottom:35%;left:50%;width:2px;transform:translateX(-50%);border-radius:2px;background:#2d2d48}.panel-header{display:flex;align-items:center;gap:.5rem;margin-bottom:.5rem}.panel-header h2{font-size:.85rem}.panel-form textarea,.panel-form input,.panel-form select{width:100%;padding:.5rem;border-radius:6px;border:1px solid #252540;background:#141420;color:#e4e4e7;font-size:.85rem}.panel-form button{margin-top:.5rem;padding:.5rem .85rem;border-radius:6px;border:none;background:#00d4aa;color:#0a0a0f;font-weight:600;cursor:pointer}.panel-result{margin-top:.75rem;padding:.65rem;background:#141420;border:1px solid #1e1e2e;border-radius:8px;font-size:.8rem;max-height:200px;overflow-y:auto}.history-list{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:.5rem}.history-item{padding:.5rem .65rem;background:#141420;border:1px solid #1e1e2e;border-radius:8px;font-size:.75rem}.history-item .meta{color:#71717a}.history-item .content{color:#d4d4d8}.history-item .reply{color:#a1a1aa;margin-top:.35rem;padding-top:.35rem;border-top:1px solid #1e1e2e}@media (max-width:768px){.panels{max-height:none;flex-direction:column}.panel-column{min-width:0;max-height:28vh}.panel-column+.panel-column{border-left:none;border-top:1px solid #1e1e2e}.panel-divider{display:none}}";
}

fn default_app_js() {
 return "(function(){var apiBase=window.location.origin;if(!apiBase||apiBase==='null'||apiBase.indexOf('http')!==0){apiBase=(window.location.protocol||'http:')+'//'+(window.location.hostname||'localhost')+':'+(window.location.port||'4040');}var m=document.getElementById('messages'),f=document.getElementById('form'),i=document.getElementById('input'),aiDot=document.getElementById('ai-dot'),aiLabel=document.getElementById('ai-label'),aiFix=document.getElementById('ai-fix');function setStatus(ok,msg){aiDot.className='ai-dot '+(ok?'connected':'disconnected');aiLabel.textContent=ok?'LLM connected':(msg||'LLM disconnected');if(ok){aiFix.classList.remove('visible');}else{aiFix.classList.add('visible');aiFix.innerHTML='<strong>Setup:</strong> Set OPENAI_API_KEY in .env and restart.';}}(async function(){try{var r=await fetch(apiBase+'/api/ai-status');var d=await r.json();setStatus(!!d.connected,d.message);}catch(e){setStatus(false,'Cannot reach server');}})();setInterval(function(){fetch(apiBase+'/api/ai-status').then(function(r){return r.json();}).then(function(d){setStatus(!!d.connected,d.message);}).catch(function(){setStatus(false);});},45000);function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}function nl2br(s){return String(s).replace(/\\n/g,'<br>');}function addMsg(who,text){var d=document.createElement('div');d.className='msg '+who;d.innerHTML='<div class=\"who\">'+who+'</div><div>'+nl2br(esc(text))+'</div>';m.appendChild(d);m.scrollTop=m.scrollHeight;}f.addEventListener('submit',async function(e){e.preventDefault();var c=i.value.trim();if(!c)return;addMsg('user',c);i.value='';i.focus();try{var r=await fetch(apiBase+'/api/message',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({sender_id:'web',content:c})});var d=await r.json();addMsg('agent',d.reply||d.error||'No reply');}catch(err){addMsg('agent','Error: '+err.message);}});var hList=document.getElementById('history-list'),hRef=document.getElementById('history-refresh'),hClr=document.getElementById('history-clear');function renderHist(entries){hList.innerHTML='';if(!entries||entries.length===0){hList.innerHTML='<div>No history yet.</div>';return;}entries.forEach(function(e){var el=document.createElement('div');el.className='history-item';el.innerHTML='<div class=\"meta\">'+(e.ts||'')+' '+esc(e.sender||'')+'</div><div class=\"content\">'+nl2br(esc((e.content||'').slice(0,200)))+'</div>'+(e.reply?'<div class=\"reply\">'+nl2br(esc((e.reply||'').slice(0,150)))+'</div>':'');hList.appendChild(el);});}async function refreshHist(){try{var r=await fetch(apiBase+'/api/history');var d=await r.json();if(d.ok&&Array.isArray(d.entries)){renderHist(d.entries);}else{renderHist([]);}}catch(e){renderHist([]);}}if(hRef){hRef.addEventListener('click',refreshHist);}if(hClr){hClr.addEventListener('click',async function(){if(!confirm('Clear history?'))return;await fetch(apiBase+'/api/history/clear',{method:'POST'});refreshHist();});}refreshHist();var taskForm=document.getElementById('task-form'),taskIn=document.getElementById('task-input'),taskRes=document.getElementById('task-result');if(taskForm){taskForm.addEventListener('submit',async function(e){e.preventDefault();var desc=(taskIn&&taskIn.value.trim())||'';if(!desc)return;taskRes.textContent='Running...';try{var r=await fetch(apiBase+'/api/task',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({description:desc})});var d=await r.json();taskRes.textContent=d.error||d.result||'Done.';if(!d.error){refreshHist();}}catch(err){taskRes.textContent='Error: '+err.message;}});}var wfForm=document.getElementById('workflow-form'),wfSel=document.getElementById('workflow-select'),wfIn=document.getElementById('workflow-input'),wfRes=document.getElementById('workflow-result');async function loadWf(){try{var r=await fetch(apiBase+'/api/workflow/list');var d=await r.json();wfSel.innerHTML='';if(d.ok&&Array.isArray(d.workflows)){d.workflows.forEach(function(w){var o=document.createElement('option');o.value=w.name;o.textContent=w.name;wfSel.appendChild(o);});}else{wfSel.innerHTML='<option value=\"\">No workflows</option>';}}catch(e){wfSel.innerHTML='<option value=\"\">Failed to load</option>';}}if(wfForm){wfForm.addEventListener('submit',async function(e){e.preventDefault();var name=wfSel.value,inp=wfIn&&wfIn.value.trim();if(!name||!inp)return;wfRes.textContent='Running...';try{var r=await fetch(apiBase+'/api/workflow',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({workflow:name,input:inp})});var d=await r.json();wfRes.textContent=d.error||d.final_result||'Done.';if(!d.error){refreshHist();}}catch(err){wfRes.textContent='Error: '+err.message;}});}loadWf();(function(){var c=document.getElementById('bottom-panels');var l=document.getElementById('panel-history');var m2=document.getElementById('panel-task');var r2=document.getElementById('panel-workflow');var d1=document.querySelector('[data-divider=\"history-task\"]');var d2=document.querySelector('[data-divider=\"task-workflow\"]');if(!c||!l||!m2||!r2||!d1||!d2)return;function set(a,b,cw){l.style.flex='0 0 '+a+'px';m2.style.flex='0 0 '+b+'px';r2.style.flex='0 0 '+cw+'px';}function cur(){return{a:l.getBoundingClientRect().width,b:m2.getBoundingClientRect().width,c:r2.getBoundingClientRect().width};}function bind(div,side){div.addEventListener('pointerdown',function(ev){if(window.matchMedia('(max-width: 768px)').matches)return;ev.preventDefault();var sx=ev.clientX;var s=cur();var min=220;function move(mev){var dx=mev.clientX-sx;var a=s.a,b=s.b,cw=s.c;if(side==='left'){a=Math.max(min,s.a+dx);b=Math.max(min,s.b-dx);}else{b=Math.max(min,s.b+dx);cw=Math.max(min,s.c-dx);}set(a,b,cw);}function up(){window.removeEventListener('pointermove',move);window.removeEventListener('pointerup',up);}window.addEventListener('pointermove',move);window.addEventListener('pointerup',up);});}bind(d1,'left');bind(d2,'right');})();})();";
}

