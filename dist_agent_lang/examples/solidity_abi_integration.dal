// Solidity ABI Integration Example
// Shows how to use ABI parsing, type safety, and event listening

@trust("hybrid")
@chain("ethereum")
service SolidityABIIntegration {
    // Example: Uniswap V2 Router ABI (simplified)
    uniswap_abi: string = `[
        {
            "type": "function",
            "name": "swapExactTokensForTokens",
            "inputs": [
                {"name": "amountIn", "type": "uint256"},
                {"name": "amountOutMin", "type": "uint256"},
                {"name": "path", "type": "address[]"},
                {"name": "to", "type": "address"},
                {"name": "deadline", "type": "uint256"}
            ],
            "outputs": [{"name": "amounts", "type": "uint256[]"}],
            "stateMutability": "nonpayable"
        },
        {
            "type": "function",
            "name": "getAmountsOut",
            "inputs": [
                {"name": "amountIn", "type": "uint256"},
                {"name": "path", "type": "address[]"}
            ],
            "outputs": [{"name": "amounts", "type": "uint256[]"}],
            "stateMutability": "view"
        },
        {
            "type": "event",
            "name": "Swap",
            "inputs": [
                {"name": "sender", "type": "address", "indexed": true},
                {"name": "amount0In", "type": "uint256", "indexed": false},
                {"name": "amount1In", "type": "uint256", "indexed": false},
                {"name": "amount0Out", "type": "uint256", "indexed": false},
                {"name": "amount1Out", "type": "uint256", "indexed": false},
                {"name": "to", "type": "address", "indexed": true}
            ],
            "anonymous": false
        }
    ]`,
    
    uniswap_router: string = "0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D",
    
    fn initialize() {
        // Register contract with ABI
        solidity_adapter::register_contract(
            "UniswapRouter",
            self.uniswap_router,
            1,  // Ethereum
            self.uniswap_abi
        );
        
        log::info("integration", "Uniswap contract registered with ABI");
    }
    
    // Type-safe swap function (generated from ABI)
    fn swap_tokens_type_safe(
        amount_in: int,
        amount_out_min: int,
        path: vector<string>,
        to: string,
        deadline: int
    ) -> vector<int> {
        // This uses ABI validation
        let result = solidity_adapter::call_with_abi(
            "UniswapRouter",
            "swapExactTokensForTokens",
            {
                "amountIn": amount_in,
                "amountOutMin": amount_out_min,
                "path": path,
                "to": to,
                "deadline": deadline
            }
        );
        
        // Parse result (would be properly typed based on ABI)
        return parse_swap_result(result);
    }
    
    // Get quote with type safety
    fn get_quote_type_safe(
        amount_in: int,
        path: vector<string>
    ) -> vector<int> {
        let result = solidity_adapter::call_with_abi(
            "UniswapRouter",
            "getAmountsOut",
            {
                "amountIn": amount_in,
                "path": path
            }
        );
        
        return parse_amounts_result(result);
    }
    
    // Listen to Swap events
    fn setup_swap_listener() {
        solidity_adapter::listen_to_event(
            "UniswapRouter",
            "Swap",
            "handle_swap_event",
            null,  // from_block (null = latest)
            null   // to_block (null = latest)
        );
        
        log::info("integration", "Swap event listener registered");
    }
    
    // Event handler callback
    fn handle_swap_event(event_data: map<string, any>) {
        log::info("swap_event", "Swap detected:");
        log::info("swap_event", "  Sender: " + event_data["sender"]);
        log::info("swap_event", "  Amount0In: " + event_data["amount0In"]);
        log::info("swap_event", "  Amount1Out: " + event_data["amount1Out"]);
        log::info("swap_event", "  To: " + event_data["to"]);
    }
    
    // Helper: Parse swap result
    fn parse_swap_result(result: string) -> vector<int> {
        // In real implementation, this would parse the actual return value
        // For now, return mock data
        return [1000000, 950000];
    }
    
    // Helper: Parse amounts result
    fn parse_amounts_result(result: string) -> vector<int> {
        // In real implementation, this would parse the actual return value
        return [1000000, 950000];
    }
}

// Auto-generated wrapper example
// This would be generated by: solidity_adapter::generate_wrapper_code()
@trust("hybrid")
service UniswapRouterWrapper {
    contract_address: string = "0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D";
    chain_id: int = 1;
    
    // Auto-generated from ABI
    fn swapExactTokensForTokens(
        amountIn: int,
        amountOutMin: int,
        path: vector<string>,
        to: string,
        deadline: int
    ) -> vector<int> {
        return chain::call(
            self.chain_id,
            self.contract_address,
            "swapExactTokensForTokens",
            {
                "amountIn": amountIn,
                "amountOutMin": amountOutMin,
                "path": path,
                "to": to,
                "deadline": deadline
            }
        );
    }
    
    fn getAmountsOut(
        amountIn: int,
        path: vector<string>
    ) -> vector<int> {
        return chain::call(
            self.chain_id,
            self.contract_address,
            "getAmountsOut",
            {
                "amountIn": amountIn,
                "path": path
            }
        );
    }
    
    // Event handler
    fn on_Swap(callback: function) {
        solidity_adapter::listen_to_event(
            self.contract_address,
            "Swap",
            callback
        );
    }
}

