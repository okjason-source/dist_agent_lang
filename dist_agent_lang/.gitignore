fix/

# Environment
.env
.env.local

# Package files (upload via GitHub Releases instead)
dist_agent_lang-*.tar.gz
dist_agent_lang-*.zip

# ============================================================================
# DOCUMENTATION: Only user-facing docs are tracked
# ============================================================================

# Ignore development/internal documentation directories (ignore entire directories)
docs/development/
docs/project/
docs/beta/
docs/testing/

# Allow user-facing documentation directories (explicitly allow)
!docs/getting_started/
!docs/guides/
!docs/tutorials/
!docs/migration/

# Allow specific root-level docs files
!docs/README.md
!docs/api_reference.md
!docs/syntax.md
!docs/attributes.md
!docs/KYC_AML_FEATURES.md
!docs/XNFT_DYNAMIC_RWA_GUIDE.md

# ============================================================================
# ROOT-LEVEL FILES: Ignore development docs, keep core project files
# ============================================================================

# Core project files (KEEP - these are user-facing)
!README.md
!CHANGELOG.md
!CONTRIBUTING.md
!CONTRIBUTORS.md
!GOOD_FIRST_ISSUES.md
!LICENSE
!SECURITY_DISCLAIMER.md

# Ignore all root-level .md files EXCEPT core files listed above
/*.md
!README.md
!CHANGELOG.md
!CONTRIBUTING.md
!CONTRIBUTORS.md
!GOOD_FIRST_ISSUES.md
!SECURITY_DISCLAIMER.md

