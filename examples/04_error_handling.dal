// Error Handling Example
// Demonstrates try-catch blocks, error recovery, and comprehensive error management

@trust(hybrid)
service ErrorHandlingDemo {
    users: map<string, User>,
    transactions: vector<Transaction>,
    error_log: vector<ErrorLog>
}

// User structure
struct User {
    id: string,
    name: string,
    balance: int,
    status: string, // "active", "suspended", "deleted"
    created_at: int
}

// Transaction structure
struct Transaction {
    id: int,
    from_user: string,
    to_user: string,
    amount: int,
    status: string, // "pending", "completed", "failed", "rolled_back"
    error_message: string,
    timestamp: int
}

// Error log structure
struct ErrorLog {
    id: int,
    error_type: string,
    error_message: string,
    user_id: string,
    transaction_id: int,
    timestamp: int,
    severity: string // "low", "medium", "high", "critical"
}

@secure
fn create_user(user_id: string, name: string, initial_balance: int) -> Result<User, string> {
    try {
        // Validate input
        if user_id == "" {
            throw "User ID cannot be empty";
        }
        
        if name == "" {
            throw "Name cannot be empty";
        }
        
        if initial_balance < 0 {
            throw "Initial balance cannot be negative";
        }
        
        // Check if user already exists
        if users.contains(user_id) {
            throw "User already exists";
        }
        
        let user = User {
            id: user_id,
            name: name,
            balance: initial_balance,
            status: "active",
            created_at: timestamp()
        };
        
        users[user_id] = user;
        
        log::audit("user_created", { 
            "user_id": user_id, 
            "name": name,
            "balance": initial_balance 
        });
        
        Ok(user)
        
    } catch (error) {
        log::error("Failed to create user", { 
            "user_id": user_id, 
            "error": error 
        });
        
        // Log error for analysis
        let error_log = ErrorLog {
            id: generate_error_id(),
            error_type: "user_creation_failed",
            error_message: error,
            user_id: user_id,
            transaction_id: 0,
            timestamp: timestamp(),
            severity: "medium"
        };
        
        error_log.push(error_log);
        
        Err(error)
    }
}

@txn
@secure
fn transfer_money(from_user: string, to_user: string, amount: int) -> Result<int, string> {
    let transaction_id = generate_transaction_id();
    
    try {
        // Validate input
        if amount <= 0 {
            throw "Transfer amount must be positive";
        }
        
        if from_user == to_user {
            throw "Cannot transfer to same user";
        }
        
        // Check if users exist
        if !users.contains(from_user) {
            throw "Source user not found";
        }
        
        if !users.contains(to_user) {
            throw "Destination user not found";
        }
        
        let from_user_obj = users[from_user];
        let to_user_obj = users[to_user];
        
        // Check user status
        if from_user_obj.status != "active" {
            throw "Source user is not active";
        }
        
        if to_user_obj.status != "active" {
            throw "Destination user is not active";
        }
        
        // Check balance
        if from_user_obj.balance < amount {
            throw "Insufficient balance";
        }
        
        // Create transaction record
        let transaction = Transaction {
            id: transaction_id,
            from_user: from_user,
            to_user: to_user,
            amount: amount,
            status: "pending",
            error_message: "",
            timestamp: timestamp()
        };
        
        transactions.push(transaction);
        
        // Perform the transfer
        from_user_obj.balance -= amount;
        to_user_obj.balance += amount;
        
        users[from_user] = from_user_obj;
        users[to_user] = to_user_obj;
        
        // Update transaction status
        transaction.status = "completed";
        transactions[transaction_id] = transaction;
        
        // Log successful transfer
        log::audit("money_transferred", { 
            "transaction_id": transaction_id,
            "from_user": from_user,
            "to_user": to_user,
            "amount": amount 
        });
        
        Ok(transaction_id)
        
    } catch (error) {
        // Update transaction status to failed
        if transactions.contains(transaction_id) {
            let transaction = transactions[transaction_id];
            transaction.status = "failed";
            transaction.error_message = error;
            transactions[transaction_id] = transaction;
        }
        
        // Log error
        log::error("Transfer failed", { 
            "transaction_id": transaction_id,
            "from_user": from_user,
            "to_user": to_user,
            "amount": amount,
            "error": error 
        });
        
        // Log error for analysis
        let error_log = ErrorLog {
            id: generate_error_id(),
            error_type: "transfer_failed",
            error_message: error,
            user_id: from_user,
            transaction_id: transaction_id,
            timestamp: timestamp(),
            severity: "high"
        };
        
        error_log.push(error_log);
        
        Err(error)
    } finally {
        // Cleanup resources
        cleanup_transaction_resources(transaction_id);
    }
}

fn rollback_transaction(transaction_id: int) -> Result<bool, string> {
    try {
        if !transactions.contains(transaction_id) {
            throw "Transaction not found";
        }
        
        let transaction = transactions[transaction_id];
        
        if transaction.status != "completed" {
            throw "Cannot rollback non-completed transaction";
        }
        
        // Get user objects
        let from_user = users[transaction.from_user];
        let to_user = users[transaction.to_user];
        
        // Reverse the transfer
        from_user.balance += transaction.amount;
        to_user.balance -= transaction.amount;
        
        users[transaction.from_user] = from_user;
        users[transaction.to_user] = to_user;
        
        // Update transaction status
        transaction.status = "rolled_back";
        transactions[transaction_id] = transaction;
        
        log::audit("transaction_rolled_back", { 
            "transaction_id": transaction_id,
            "amount": transaction.amount 
        });
        
        Ok(true)
        
    } catch (error) {
        log::error("Rollback failed", { 
            "transaction_id": transaction_id,
            "error": error 
        });
        
        Err(error)
    }
}

fn safe_divide(numerator: int, denominator: int) -> Result<float, string> {
    try {
        if denominator == 0 {
            throw "Division by zero";
        }
        
        let result = numerator / denominator;
        Ok(result)
        
    } catch (error) {
        log::error("Division error", { 
            "numerator": numerator,
            "denominator": denominator,
            "error": error 
        });
        
        Err(error)
    }
}

fn process_batch_transfers(transfers: vector<map<string, any>>) -> map<string, any> {
    let results = {
        "successful": 0,
        "failed": 0,
        "errors": vector<string>()
    };
    
    for transfer in transfers {
        try {
            let from_user = transfer["from"];
            let to_user = transfer["to"];
            let amount = transfer["amount"];
            
            let result = transfer_money(from_user, to_user, amount);
            
            if result.is_ok() {
                results["successful"] += 1;
            } else {
                results["failed"] += 1;
                results["errors"].push(result.unwrap_err());
            }
            
        } catch (error) {
            results["failed"] += 1;
            results["errors"].push(error);
            
            log::error("Batch transfer error", { 
                "transfer": transfer,
                "error": error 
            });
        }
    }
    
    log::info("Batch processing completed", {
        "successful": results["successful"],
        "failed": results["failed"],
        "total": transfers.size()
    });
    
    results
}

fn get_error_statistics() -> map<string, any> {
    let stats = {
        "total_errors": error_log.size(),
        "by_severity": {
            "low": 0,
            "medium": 0,
            "high": 0,
            "critical": 0
        },
        "by_type": map<string, int>(),
        "recent_errors": vector<ErrorLog>()
    };
    
    for error in error_log {
        // Count by severity
        let severity = error.severity;
        stats["by_severity"][severity] += 1;
        
        // Count by type
        let error_type = error.error_type;
        if stats["by_type"].contains(error_type) {
            stats["by_type"][error_type] += 1;
        } else {
            stats["by_type"][error_type] = 1;
        }
        
        // Get recent errors (last 24 hours)
        let one_day_ago = timestamp() - 86400;
        if error.timestamp > one_day_ago {
            stats["recent_errors"].push(error);
        }
    }
    
    stats
}

fn cleanup_transaction_resources(transaction_id: int) {
    // Cleanup any temporary resources
    // This is called in finally blocks
    log::debug("Cleaning up transaction resources", { 
        "transaction_id": transaction_id 
    });
}

fn generate_transaction_id() -> int {
    // Simple ID generation
    transactions.size() + 1
}

fn generate_error_id() -> int {
    // Simple ID generation
    error_log.size() + 1
}

// Main function to demonstrate error handling
fn main() {
    // Create users with error handling
    let user1_result = create_user("alice", "Alice Johnson", 1000);
    let user2_result = create_user("bob", "Bob Smith", 500);
    let user3_result = create_user("", "Invalid User", 100); // This will fail
    
    // Handle user creation results
    if user1_result.is_ok() {
        log::info("User created successfully", { "user": "alice" });
    } else {
        log::error("Failed to create user", { "user": "alice", "error": user1_result.unwrap_err() });
    }
    
    if user2_result.is_ok() {
        log::info("User created successfully", { "user": "bob" });
    } else {
        log::error("Failed to create user", { "user": "bob", "error": user2_result.unwrap_err() });
    }
    
    if user3_result.is_ok() {
        log::info("User created successfully", { "user": "invalid" });
    } else {
        log::error("Failed to create user", { "user": "invalid", "error": user3_result.unwrap_err() });
    }
    
    // Perform transfers with error handling
    let transfer1_result = transfer_money("alice", "bob", 200);
    let transfer2_result = transfer_money("alice", "bob", 1000); // This will fail (insufficient balance)
    let transfer3_result = transfer_money("alice", "nonexistent", 100); // This will fail (user not found)
    
    // Handle transfer results
    if transfer1_result.is_ok() {
        log::info("Transfer successful", { "transaction_id": transfer1_result.unwrap() });
    } else {
        log::error("Transfer failed", { "error": transfer1_result.unwrap_err() });
    }
    
    if transfer2_result.is_ok() {
        log::info("Transfer successful", { "transaction_id": transfer2_result.unwrap() });
    } else {
        log::error("Transfer failed", { "error": transfer2_result.unwrap_err() });
    }
    
    if transfer3_result.is_ok() {
        log::info("Transfer successful", { "transaction_id": transfer3_result.unwrap() });
    } else {
        log::error("Transfer failed", { "error": transfer3_result.unwrap_err() });
    }
    
    // Demonstrate safe division
    let division1_result = safe_divide(10, 2);
    let division2_result = safe_divide(10, 0); // This will fail
    
    if division1_result.is_ok() {
        log::info("Division successful", { "result": division1_result.unwrap() });
    } else {
        log::error("Division failed", { "error": division1_result.unwrap_err() });
    }
    
    if division2_result.is_ok() {
        log::info("Division successful", { "result": division2_result.unwrap() });
    } else {
        log::error("Division failed", { "error": division2_result.unwrap_err() });
    }
    
    // Process batch transfers
    let batch_transfers = vector<map<string, any>>(
        { "from": "alice", "to": "bob", "amount": 50 },
        { "from": "bob", "to": "alice", "amount": 25 },
        { "from": "alice", "to": "nonexistent", "amount": 100 }, // This will fail
        { "from": "alice", "to": "bob", "amount": 1000 } // This will fail (insufficient balance)
    );
    
    let batch_results = process_batch_transfers(batch_transfers);
    
    // Get error statistics
    let error_stats = get_error_statistics();
    
    log::info("Error handling demo completed", {
        "batch_successful": batch_results["successful"],
        "batch_failed": batch_results["failed"],
        "total_errors": error_stats["total_errors"],
        "critical_errors": error_stats["by_severity"]["critical"]
    });
    
    null
}
