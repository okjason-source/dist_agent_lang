// AI-Powered Trading Bot Example
// Demonstrates async/await, agent system, oracle integration, and AI services

@trust(hybrid)
service TradingBot {
    agents: map<int, TradingAgent>,
    strategies: map<string, TradingStrategy>,
    risk_limits: map<string, int>,
    market_data: map<string, MarketData>
}

// Trading agent structure
struct TradingAgent {
    id: int,
    user_id: string,
    strategy: string,
    capital: int,
    holdings: map<string, int>,
    active: bool,
    created_at: int,
    last_trade: int
}

// Trading strategy structure
struct TradingStrategy {
    name: string,
    description: string,
    risk_level: string,
    min_capital: int,
    max_position_size: int,
    stop_loss_percentage: float
}

// Market data structure
struct MarketData {
    symbol: string,
    price: float,
    volume: int,
    timestamp: int,
    change_24h: float
}

// Trading decision structure
struct TradingDecision {
    action: string,  // "buy", "sell", "hold"
    symbol: string,
    amount: int,
    confidence: float,
    reason: string
}

@secure
fn create_trading_strategy(name: string, risk_level: string, min_capital: int) -> bool {
    let strategy = TradingStrategy {
        name: name,
        description: "AI-powered trading strategy",
        risk_level: risk_level,
        min_capital: min_capital,
        max_position_size: min_capital * 0.1, // 10% of capital
        stop_loss_percentage: 0.05 // 5% stop loss
    };
    
    strategies[name] = strategy;
    
    log::audit("strategy_created", { 
        "name": name, 
        "risk_level": risk_level,
        "min_capital": min_capital 
    });
    
    true
}

async fn create_trading_agent(user_id: string, strategy_name: string, capital: int) -> int {
    if !strategies.contains(strategy_name) {
        log::error("Strategy not found", { "strategy": strategy_name });
        return -1;
    }
    
    let strategy = strategies[strategy_name];
    
    if capital < strategy.min_capital {
        log::error("Insufficient capital", { 
            "capital": capital, 
            "min_capital": strategy.min_capital 
        });
        return -1;
    }
    
    let agent_id = generate_agent_id();
    
    let agent = TradingAgent {
        id: agent_id,
        user_id: user_id,
        strategy: strategy_name,
        capital: capital,
        holdings: map<string, int>(),
        active: true,
        created_at: timestamp(),
        last_trade: 0
    };
    
    agents[agent_id] = agent;
    
    // Set risk limit for user
    risk_limits[user_id] = capital * 0.2; // 20% of capital as risk limit
    
    // Spawn the trading agent
    let worker = spawn agent {
        trading_loop(agent_id);
    };
    
    log::audit("trading_agent_created", { 
        "agent_id": agent_id, 
        "user_id": user_id, 
        "strategy": strategy_name,
        "capital": capital 
    });
    
    agent_id
}

async fn trading_loop(agent_id: int) {
    let agent = agents[agent_id];
    
    log::info("Trading agent started", { "agent_id": agent_id });
    
    while agent.active {
        try {
            // Get market data from oracle
            let btc_price = await oracle::fetch("price_feed", oracle::create_query("BTC"));
            let eth_price = await oracle::fetch("price_feed", oracle::create_query("ETH"));
            let ada_price = await oracle::fetch("price_feed", oracle::create_query("ADA"));
            
            // Update market data
            market_data["BTC"] = MarketData {
                symbol: "BTC",
                price: btc_price,
                volume: 1000000,
                timestamp: timestamp(),
                change_24h: 0.05
            };
            
            market_data["ETH"] = MarketData {
                symbol: "ETH",
                price: eth_price,
                volume: 500000,
                timestamp: timestamp(),
                change_24h: 0.03
            };
            
            market_data["ADA"] = MarketData {
                symbol: "ADA",
                price: ada_price,
                volume: 200000,
                timestamp: timestamp(),
                change_24h: -0.02
            };
            
            // Get AI analysis
            let ai_service = service::create_ai_service("gpt-4");
            let market_analysis = await service::ai(
                "Analyze current BTC, ETH, and ADA market conditions. " +
                "Consider price trends, volume, and market sentiment. " +
                "Provide trading recommendations.",
                ai_service
            );
            
            // Execute trading strategy
            let decision = analyze_market(agent_id, market_analysis);
            
            if decision.action != "hold" {
                let success = await execute_trade(agent_id, decision);
                
                if success {
                    log::info("Trade executed", {
                        "agent_id": agent_id,
                        "action": decision.action,
                        "symbol": decision.symbol,
                        "amount": decision.amount,
                        "confidence": decision.confidence
                    });
                }
            }
            
            // Wait for next cycle (5 minutes)
            await sleep(300);
            
        } catch (error) {
            log::error("Trading loop error", { 
                "agent_id": agent_id, 
                "error": error 
            });
            
            // Wait before retrying
            await sleep(60);
        }
    }
    
    log::info("Trading agent stopped", { "agent_id": agent_id });
}

fn analyze_market(agent_id: int, ai_analysis: string) -> TradingDecision {
    let agent = agents[agent_id];
    let strategy = strategies[agent.strategy];
    
    // Simple market analysis based on AI input and current prices
    let btc_data = market_data["BTC"];
    let eth_data = market_data["ETH"];
    let ada_data = market_data["ADA"];
    
    // Analyze price movements
    let btc_trend = btc_data.change_24h > 0.02; // 2% positive change
    let eth_trend = eth_data.change_24h > 0.01;  // 1% positive change
    let ada_trend = ada_data.change_24h < -0.01; // 1% negative change
    
    // Simple decision logic
    if btc_trend && agent.capital >= strategy.max_position_size {
        return TradingDecision {
            action: "buy",
            symbol: "BTC",
            amount: strategy.max_position_size,
            confidence: 0.7,
            reason: "BTC showing positive trend"
        };
    } else if eth_trend && agent.capital >= strategy.max_position_size {
        return TradingDecision {
            action: "buy",
            symbol: "ETH",
            amount: strategy.max_position_size,
            confidence: 0.6,
            reason: "ETH showing positive trend"
        };
    } else if ada_trend && agent.holdings.contains("ADA") && agent.holdings["ADA"] > 0 {
        return TradingDecision {
            action: "sell",
            symbol: "ADA",
            amount: agent.holdings["ADA"],
            confidence: 0.8,
            reason: "ADA showing negative trend"
        };
    }
    
    // Default: hold
    TradingDecision {
        action: "hold",
        symbol: "",
        amount: 0,
        confidence: 0.5,
        reason: "No clear trading opportunity"
    }
}

@secure
@limit(1000)
async fn execute_trade(agent_id: int, decision: TradingDecision) -> bool {
    let agent = agents[agent_id];
    
    // Check risk limits
    if decision.amount > risk_limits[agent.user_id] {
        log::warning("Risk limit exceeded", { 
            "agent_id": agent_id, 
            "amount": decision.amount, 
            "limit": risk_limits[agent.user_id] 
        });
        return false;
    }
    
    // Execute the trade
    let trade_metadata = {
        "agent_id": agent_id,
        "action": decision.action,
        "symbol": decision.symbol,
        "amount": decision.amount,
        "confidence": decision.confidence,
        "reason": decision.reason,
        "timestamp": timestamp()
    };
    
    let success = chain::mint("trade", trade_metadata);
    
    if success {
        // Update agent holdings
        if decision.action == "buy" {
            agent.capital -= decision.amount;
            if agent.holdings.contains(decision.symbol) {
                agent.holdings[decision.symbol] += decision.amount;
            } else {
                agent.holdings[decision.symbol] = decision.amount;
            }
        } else if decision.action == "sell" {
            agent.capital += decision.amount;
            agent.holdings[decision.symbol] -= decision.amount;
        }
        
        agent.last_trade = timestamp();
        agents[agent_id] = agent;
        
        log::audit("trade_executed", { 
            "agent_id": agent_id, 
            "action": decision.action, 
            "symbol": decision.symbol,
            "amount": decision.amount,
            "success": true 
        });
    }
    
    success
}

fn get_agent_status(agent_id: int) -> map<string, any> {
    if !agents.contains(agent_id) {
        return { "error": "Agent not found" };
    }
    
    let agent = agents[agent_id];
    let strategy = strategies[agent.strategy];
    
    {
        "id": agent.id,
        "user_id": agent.user_id,
        "strategy": agent.strategy,
        "capital": agent.capital,
        "holdings": agent.holdings,
        "active": agent.active,
        "created_at": agent.created_at,
        "last_trade": agent.last_trade,
        "strategy_info": {
            "name": strategy.name,
            "risk_level": strategy.risk_level,
            "max_position_size": strategy.max_position_size
        }
    }
}

fn stop_agent(agent_id: int) -> bool {
    if !agents.contains(agent_id) {
        return false;
    }
    
    let agent = agents[agent_id];
    agent.active = false;
    agents[agent_id] = agent;
    
    log::audit("agent_stopped", { "agent_id": agent_id });
    true
}

// Main function to demonstrate the trading bot
async fn main() {
    // Create trading strategies
    create_trading_strategy("conservative", "low", 1000);
    create_trading_strategy("moderate", "medium", 5000);
    create_trading_strategy("aggressive", "high", 10000);
    
    // Create trading agents
    let agent1 = await create_trading_agent("user1", "conservative", 2000);
    let agent2 = await create_trading_agent("user2", "moderate", 8000);
    let agent3 = await create_trading_agent("user3", "aggressive", 15000);
    
    // Let agents run for a while
    await sleep(600); // 10 minutes
    
    // Check agent statuses
    let status1 = get_agent_status(agent1);
    let status2 = get_agent_status(agent2);
    let status3 = get_agent_status(agent3);
    
    log::info("Trading bot demo completed", {
        "agent1_capital": status1["capital"],
        "agent2_capital": status2["capital"],
        "agent3_capital": status3["capital"],
        "total_agents": agents.size()
    });
    
    // Stop agents
    stop_agent(agent1);
    stop_agent(agent2);
    stop_agent(agent3);
    
    null
}
