// NFT Marketplace Example
// Demonstrates blockchain operations, attributes, and complex data structures

@trust(hybrid)
service NFTMarketplace {
    users: map<string, User>,
    nfts: map<int, NFT>,
    transactions: vector<Transaction>
}

// User structure
struct User {
    id: string,
    name: string,
    balance: int,
    nfts: vector<int>,
    created_at: int
}

// NFT structure
struct NFT {
    id: int,
    name: string,
    description: string,
    creator: string,
    owner: string,
    price: int,
    for_sale: bool,
    created_at: int
}

// Transaction structure
struct Transaction {
    id: int,
    nft_id: int,
    from: string,
    to: string,
    amount: int,
    timestamp: int
}

@secure
fn create_user(user_id: string, name: string) -> bool {
    let user = User {
        id: user_id,
        name: name,
        balance: 1000, // Starting balance
        nfts: vector<int>(),
        created_at: timestamp()
    };
    
    users[user_id] = user;
    
    log::audit("user_created", { "user_id": user_id, "name": name });
    true
}

@secure
@limit(100)
fn create_nft(name: string, description: string, creator: string) -> int {
    // Validate creator exists
    if !users.contains(creator) {
        log::error("Creator not found", { "creator": creator });
        return -1;
    }
    
    let metadata = {
        "name": name,
        "description": description,
        "creator": creator,
        "created_at": timestamp()
    };
    
    // Mint NFT on blockchain
    let asset_id = chain::mint(name, metadata);
    
    let nft = NFT {
        id: asset_id,
        name: name,
        description: description,
        creator: creator,
        owner: creator,
        price: 0,
        for_sale: false,
        created_at: timestamp()
    };
    
    nfts[asset_id] = nft;
    users[creator].nfts.push(asset_id);
    
    log::audit("nft_created", { 
        "asset_id": asset_id, 
        "creator": creator,
        "name": name 
    });
    
    asset_id
}

@txn
@limit(50)
fn list_nft(nft_id: int, price: int, seller: string) -> bool {
    if !nfts.contains(nft_id) {
        log::error("NFT not found", { "nft_id": nft_id });
        return false;
    }
    
    let nft = nfts[nft_id];
    
    if nft.owner != seller {
        log::error("Seller not owner", { "seller": seller, "owner": nft.owner });
        return false;
    }
    
    if price <= 0 {
        log::error("Invalid price", { "price": price });
        return false;
    }
    
    nft.price = price;
    nft.for_sale = true;
    nfts[nft_id] = nft;
    
    log::audit("nft_listed", { 
        "nft_id": nft_id, 
        "price": price, 
        "seller": seller 
    });
    
    true
}

@txn
@secure
fn buy_nft(nft_id: int, buyer: string) -> bool {
    if !nfts.contains(nft_id) {
        log::error("NFT not found", { "nft_id": nft_id });
        return false;
    }
    
    if !users.contains(buyer) {
        log::error("Buyer not found", { "buyer": buyer });
        return false;
    }
    
    let nft = nfts[nft_id];
    
    if !nft.for_sale {
        log::error("NFT not for sale", { "nft_id": nft_id });
        return false;
    }
    
    let buyer_user = users[buyer];
    
    if buyer_user.balance < nft.price {
        log::error("Insufficient balance", { 
            "buyer": buyer, 
            "balance": buyer_user.balance, 
            "price": nft.price 
        });
        return false;
    }
    
    let seller = nft.owner;
    let seller_user = users[seller];
    
    // Transfer ownership
    nft.owner = buyer;
    nft.for_sale = false;
    nft.price = 0;
    nfts[nft_id] = nft;
    
    // Update balances
    buyer_user.balance -= nft.price;
    seller_user.balance += nft.price;
    
    // Update NFT collections
    buyer_user.nfts.push(nft_id);
    seller_user.nfts.remove(nft_id);
    
    users[buyer] = buyer_user;
    users[seller] = seller_user;
    
    // Record transaction
    let transaction = Transaction {
        id: generate_transaction_id(),
        nft_id: nft_id,
        from: seller,
        to: buyer,
        amount: nft.price,
        timestamp: timestamp()
    };
    
    transactions.push(transaction);
    
    // Update blockchain
    chain::update(nft_id, { "owner": buyer, "last_transaction": timestamp() });
    
    log::audit("nft_purchased", { 
        "nft_id": nft_id, 
        "buyer": buyer, 
        "seller": seller,
        "amount": nft.price 
    });
    
    true
}

fn get_nft_info(nft_id: int) -> map<string, any> {
    if !nfts.contains(nft_id) {
        return { "error": "NFT not found" };
    }
    
    let nft = nfts[nft_id];
    let creator_user = users[nft.creator];
    let owner_user = users[nft.owner];
    
    {
        "id": nft.id,
        "name": nft.name,
        "description": nft.description,
        "creator": {
            "id": nft.creator,
            "name": creator_user.name
        },
        "owner": {
            "id": nft.owner,
            "name": owner_user.name
        },
        "price": nft.price,
        "for_sale": nft.for_sale,
        "created_at": nft.created_at
    }
}

fn get_user_nfts(user_id: string) -> vector<map<string, any>> {
    if !users.contains(user_id) {
        return vector<map<string, any>>();
    }
    
    let user = users[user_id];
    let user_nfts = vector<map<string, any>>();
    
    for nft_id in user.nfts {
        let nft_info = get_nft_info(nft_id);
        user_nfts.push(nft_info);
    }
    
    user_nfts
}

// Main function to demonstrate the marketplace
fn main() {
    // Create users
    create_user("alice", "Alice Johnson");
    create_user("bob", "Bob Smith");
    create_user("charlie", "Charlie Brown");
    
    // Create NFTs
    let nft1 = create_nft("Digital Art #1", "A beautiful digital artwork", "alice");
    let nft2 = create_nft("Crypto Punk #42", "A rare crypto punk", "bob");
    let nft3 = create_nft("Virtual Land #7", "A piece of virtual real estate", "charlie");
    
    // List NFTs for sale
    list_nft(nft1, 100, "alice");
    list_nft(nft2, 500, "bob");
    
    // Buy NFTs
    buy_nft(nft1, "charlie");
    buy_nft(nft2, "alice");
    
    // Display results
    let alice_nfts = get_user_nfts("alice");
    let bob_nfts = get_user_nfts("bob");
    let charlie_nfts = get_user_nfts("charlie");
    
    log::info("Marketplace demo completed", {
        "alice_nfts": alice_nfts.size(),
        "bob_nfts": bob_nfts.size(),
        "charlie_nfts": charlie_nfts.size(),
        "total_transactions": transactions.size()
    });
    
    null
}
