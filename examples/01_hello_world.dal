// Hello World Example
// Demonstrates basic language features: variables, functions, and logging

fn main() {
    // Basic variable assignment
    let message = "Hello from dist_agent_lang!";
    let version = "1.0.0";
    
    // Function call with logging
    log::info("Application started", { "version": version, "timestamp": 1234567890 });
    
    // Print to console
    print(message);
    
    // Basic arithmetic
    let x = 42;
    let y = 8;
    let sum = add(x, y);
    
    log::info("Calculation completed", { "x": x, "y": y, "sum": sum });
    
    // Return null to indicate successful completion
    null
}
